---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import WhyChooseUsSection from '../components/WhyChooseUsSection.astro';
import ConsultationSection from '../components/ConsultationSection.astro';
import Footer from '../components/Footer.astro';
import { allScams } from '../data/scam-pages';

/* ────────────────────────────────────────────
   Static paths — generates all 6 scam pages
   ──────────────────────────────────────────── */
export async function getStaticPaths() {
  return allScams.map((scam) => ({
    params: { slug: scam.slug },
    props: {
      ...scam,
      relatedScams: allScams
        .filter((s) => s.slug !== scam.slug)
        .map(({ slug, scamType, iconPath }) => ({ slug, scamType, iconPath })),
    },
  }));
}

/* ────────────────────────────────────────────
   Current page
   ──────────────────────────────────────────── */
const base = import.meta.env.BASE_URL;
const siteUrl = "https://classick-o.github.io/ScamHelp";

const { slug } = Astro.params;
const scam = Astro.props;
const canonical = `${siteUrl}/contact-${slug}-scams/`;

/* Schema.org — BreadcrumbList */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Common Scams", "item": `${siteUrl}/scams/` },
    { "@type": "ListItem", "position": 3, "name": `${scam.scamType} Scam Recovery` },
  ],
};

/* Schema.org — Service */
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${scam.scamType} Scam Recovery`,
  "description": scam.seoDescription,
  "url": canonical,
  "provider": {
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`,
    "name": "ScamHelp",
  },
  "areaServed": "Worldwide",
  "serviceType": "Fund Recovery",
};
---

<Layout title={scam.seoTitle} description={scam.seoDescription} canonical={canonical}>
  <Navbar />
  <main class="bg-[#0a0a0f]">

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />



    <!-- ─── HERO ─── -->
    <section class="px-6 text-center relative overflow-hidden" style="padding-top:4rem;padding-bottom:3rem;">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/4 rounded-full blur-[200px] pointer-events-none"></div>

      <div class="max-w-3xl mx-auto relative z-10">
        <h1 class="text-white reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(36px,5.5vw,64px);font-weight:700;line-height:1.08">
          {scam.heroTitle}<br/><span class="text-[#9ACF84]">{scam.heroHighlight}</span>
        </h1>
      </div>
    </section>


    <!-- ─── CONTENT SECTION ─── -->
    <section class="pb-16 md:pb-24 px-6 relative overflow-hidden">
      <div class="relative z-10 max-w-4xl mx-auto">
        <h2 class="text-white mb-6 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(22px,3vw,32px);font-weight:700;line-height:1.15">
          {scam.contentTitle} <span class="text-[#9ACF84]">{scam.contentHighlight}</span>
        </h2>
        {scam.contentParagraphs.map((p: string) => (
          <p class="text-white/45 mb-5 reveal" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">{p}</p>
        ))}
      </div>
    </section>


    <!-- ─── WHY CHOOSE US (shared component) ─── -->
    <WhyChooseUsSection />


    <!-- ─── CONSULTATION FORM (shared component) ─── -->
    <ConsultationSection />


    <!-- ─── WHO CAN WE HELP — green banner ─── -->
    <section class="relative overflow-hidden" aria-label="Who can we help">
      <div class="bg-[#9ACF84] py-12 md:py-16 px-6">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-12">
          <div class="flex-1 reveal">
            <h2 class="text-white mb-4" style="font-family:'Montserrat',sans-serif;font-size:clamp(24px,3.5vw,36px);font-weight:700;line-height:1.15">
              Who can we help?
            </h2>
            <p class="text-white/85" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.75">
              If you're a victim of online fraud, you're not alone! Scam Help specializes in recovering assets lost to various online financial frauds. We craft winning strategies tailored to our client's needs and budget.
            </p>
          </div>
          <div class="flex-shrink-0 reveal from-right">
            <a
              href="#consultation"
              class="inline-flex items-center gap-2 px-8 py-4 bg-white text-[#0a0a0f] rounded-full hover:bg-white/90 transition-colors btn-scale"
              style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600"
            >
              Get in Touch
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── OTHER SCAMS WE HANDLE ─── -->
    <section class="py-16 md:py-20 px-6 border-t border-white/5 relative overflow-hidden" aria-label="Related scam types">
      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="text-center mb-12 reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-4 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Explore More</span>
          <h2 class="text-white" style="font-family:'Montserrat',sans-serif;font-size:clamp(22px,3vw,34px);font-weight:600;line-height:1.15">
            Other Scams <span class="text-[#9ACF84]">We Handle</span>
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
          {scam.relatedScams.map((rs: { slug: string; scamType: string; iconPath: string }, i: number) => (
            <a href={`${base}/contact-${rs.slug}-scams`} class={`related-card reveal delay-${Math.min(i + 1, 5)}`}>
              <div class="w-10 h-10 rounded-xl bg-[#9ACF84]/8 flex items-center justify-center mb-3">
                <svg class="w-5 h-5 text-[#9ACF84]/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={rs.iconPath} />
                </svg>
              </div>
              <span class="text-white/70 block" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">{rs.scamType} Scams</span>
              <svg class="w-4 h-4 text-[#9ACF84]/40 mt-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>


<style>
  /* ── Related scam cards ── */
  .related-card {
    display: block;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid rgba(255,255,255,0.05);
    background: rgba(255,255,255,0.02);
    text-decoration: none;
    transition: border-color 0.3s, background 0.3s, transform 0.3s;
  }
  .related-card:hover {
    border-color: rgba(154,207,132,0.2);
    background: rgba(154,207,132,0.04);
    transform: translateY(-2px);
  }
</style>
