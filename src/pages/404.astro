---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Page Not Found — ScamHelp"
  description="The page you're looking for doesn't exist. Return to ScamHelp homepage."
>
  <Navbar />
  <main class="bg-[#0a0a0f] min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <p class="text-[#9ACF84] select-none" style="font-family:'Montserrat',sans-serif;font-size:clamp(80px,15vw,180px);font-weight:800;opacity:0.15;line-height:1;">
        404
      </p>
      <h1 class="text-white mt-4" style="font-family:'Montserrat',sans-serif;font-size:clamp(24px,4vw,40px);font-weight:600;">
        Page Not Found
      </h1>
      <p class="text-white/40 mt-4 max-w-md mx-auto" style="font-family:'Inter',sans-serif;font-size:16px;line-height:1.7;">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex items-center justify-center gap-4 mt-8 flex-wrap">
        <a
          href={base}
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors"
          style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600;"
        >
          Back to Home
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a
          href={`${base}/contact-us`}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/10 text-white/60 hover:text-[#9ACF84] hover:border-[#9ACF84]/30 transition-all"
          style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600;"
        >
          Contact Us
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </main>
</Layout>
