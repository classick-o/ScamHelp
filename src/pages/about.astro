---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import ConsultationSection from '../components/ConsultationSection.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const siteUrl = "https://classick-o.github.io/ScamHelp";
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "About Us" },
  ],
};

const whyUsFeatures = [
  {
    title: "Best Industry",
    highlight: "leaders",
    description: "Our team consists of international AML and law experts that are capable of solving cases of any complexity on a global scale.",
    iconPath: "M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100 8 4 4 0 000-8zm7 0a4 4 0 100 8 4 4 0 000-8m6 14v-2a4 4 0 00-3-3.87",
  },
  {
    title: "Quick",
    highlight: "Processing",
    description: "Scam Help's clients gain from our team's vast knowledge and expertise. We present your case in front of the bank or other financial institutions involved in the most professional way to reduce processing time and increase your chance for a successful resolution.",
    iconPath: "M13 2L3 14h9l-1 8 10-12h-9l1-8z",
  },
  {
    title: "Tailor-made",
    highlight: "dispute resolution",
    description: "We practice an individual approach to each client that guarantees thorough analysis of every case in order to provide our clients with the best solution available.",
    iconPath: "M12 15a3 3 0 100-6 3 3 0 000 6zM19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z",
  },
];

const helpCards = [
  {
    title: "Forex",
    highlight: "frauds",
    description: "In the dynamic foreign exchange (forex) market, characterized by constant price fluctuations, institutions, companies, and individuals can reap significant profits. Unfortunately, forex fraud is on the rise, presenting a considerable challenge without guaranteed preventive measures.",
    iconPath: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
  },
  {
    title: "Crypto",
    highlight: "scams",
    description: "Cryptocurrency scams pose a significant threat in the digital realm. Whether you've fallen victim to credit/debit card scams, online dating fraud, online casino scams, crypto-currency schemes, CFD trading fraud, or any form of banking deception, there are legitimate solutions and strategies to reclaim what is rightfully yours.",
    iconPath: "M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z",
  },
  {
    title: "Other",
    highlight: "scams",
    description: "Whether you've encountered credit/debit card scams, fallen prey to online dating schemes, been swindled by online casino fraud, entangled in CFD trading deceit, or experienced any other form of banking fraud, rest assured there is a legitimate solution and strategy to reclaim what is rightfully yours.",
    iconPath: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z",
  },
];
---

<Layout title="About Us — ScamHelp" description="Scam Help is a funds recovery company based in the Netherlands. Our dedicated team of IT forensic analysts, anti-fraud specialists, and case coordinators help victims recover lost assets." canonical="https://classick-o.github.io/ScamHelp/about/">
  <Navbar />
  <main class="bg-[#0a0a0f]">

    <!-- Breadcrumb JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- Breadcrumb -->
    <nav class="max-w-7xl mx-auto px-6 lg:px-8 pt-24 pb-0" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-[12px]" style="font-family:'Inter',sans-serif">
        <li><a href={base} class="text-white/30 hover:text-[#9ACF84] transition-colors">Home</a></li>
        <li class="text-white/15">/</li>
        <li class="text-[#9ACF84]/60">About Us</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="px-6 text-center" style="padding-top:5rem;padding-bottom:5rem;">
      <div class="max-w-3xl mx-auto">
        <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block reveal" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">About Us</span>
        <h1 class="text-white mb-5 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:700;line-height:1.1">
          Reclaim Your <span class="text-[#9ACF84]">Lost Assets!</span>
        </h1>
        <p class="text-white/40 max-w-xl mx-auto reveal" style="font-family:'Inter',sans-serif;font-size:16px;line-height:1.7">
          We help victims of online fraud recover what's rightfully theirs through expert guidance and tailored recovery strategies.
        </p>
      </div>
    </section>

    <!-- Who we are -->
    <section class="py-16 md:py-24 px-6">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Text -->
        <div class="reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-4 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Our Story</span>
          <h2 class="text-white mb-6" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            Who we <span class="text-[#9ACF84]">are?</span>
          </h2>
          <p class="text-white/45 mb-5" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Scam Help <span class="text-[#9ACF84]/70">(registered in The Netherlands under Transparent Business Solutions B.V., Company Number 78091624)</span> is a funds recovery company based in the Netherlands. Our dedicated team of professional IT forensic analysts, anti-fraud specialists, and case coordinators have vast working knowledge in online trading scams and other types of fraud.
          </p>
          <p class="text-white/45 mb-8" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            We assist clients globally to submit disputes against fraudulent entities. Scam Help guides clients with high-end tailor-made solutions with global industry-leading partners.
          </p>
          <a href="https://www.kvk.nl/bestellen/#/78091624000045743274" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
            Company Registration
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>

        <!-- Image placeholder -->
        <div class="reveal from-right rounded-2xl border border-white/5 bg-white/[0.02] overflow-hidden flex items-center justify-center" style="height:400px;">
          <div class="text-center">
            <svg class="w-16 h-16 text-[#9ACF84]/30 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <p class="text-white/20" style="font-size:13px">Image placeholder</p>
          </div>
        </div>

      </div>
    </section>

    <!-- Who can we help (white bg) -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/5 rounded-full blur-[150px] pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="text-center mb-14 reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Our Expertise</span>
          <h2 class="text-[#0a0a0f] mb-4" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            Who can we <span class="text-[#9ACF84]">help?</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
          {helpCards.map((card, i) => (
            <div class={`reveal delay-${i + 1} group p-7 rounded-2xl border border-[#e8e8e8] bg-white hover:border-[#9ACF84]/30 hover:shadow-lg transition-all duration-300`}>
              <!-- Icon -->
              <div class="w-14 h-14 rounded-xl bg-[#9ACF84]/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={card.iconPath} />
                </svg>
              </div>
              <h3 class="text-[#0a0a0f] mb-3" style="font-family:'Montserrat',sans-serif;font-size:18px;font-weight:600">
                {card.title} <span class="text-[#9ACF84]">{card.highlight}</span>
              </h3>
              <p class="text-[#0a0a0f]/50" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">{card.description}</p>
            </div>
          ))}
        </div>

        <div class="text-center mt-10 reveal">
          <a href={`${base}/scams`} class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-[#0a0a0f]/10 text-[#0a0a0f]/60 hover:text-[#9ACF84] hover:border-[#9ACF84]/30 transition-all" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
            Learn More
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Why us (white bg) -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="max-w-7xl mx-auto">

        <!-- Heading -->
        <div class="text-center mb-14 reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Our Advantage</span>
          <h2 class="text-[#0a0a0f] mb-5" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            Why <span class="text-[#9ACF84]">us?</span>
          </h2>
          <p class="text-[#0a0a0f]/50 max-w-3xl mx-auto" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Scam Help employs existing regulations, consumer rights, and tailored solutions for a top-tier recovery service. Upon confirming your valid request and fraud occurrence, you'll receive guidance to initiate the refund process. We collaborate on the best action plan to successfully recover your funds, providing a free consultation to kickstart your case.
          </p>
        </div>

        <!-- Features + Image -->
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Image placeholder -->
          <div class="reveal rounded-2xl border border-[#e8e8e8] bg-[#f8f8f8] overflow-hidden flex items-center justify-center order-2 lg:order-1" style="height:450px;">
            <div class="text-center">
              <svg class="w-16 h-16 text-[#9ACF84]/30 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <p class="text-white/20" style="font-size:13px">Image placeholder</p>
            </div>
          </div>

          <!-- Features list -->
          <div class="space-y-8 order-1 lg:order-2">
            {whyUsFeatures.map((feature, i) => (
              <div class={`reveal delay-${i + 1} flex gap-5`}>
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 rounded-xl bg-[#9ACF84]/10 border border-[#9ACF84]/20 flex items-center justify-center">
                    <svg class="w-5 h-5 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d={feature.iconPath} />
                    </svg>
                  </div>
                  {i < whyUsFeatures.length - 1 && (
                    <div class="w-px h-8 bg-[#9ACF84]/15 mx-auto mt-2"></div>
                  )}
                </div>
                <div>
                  <h3 class="text-[#0a0a0f] mb-2" style="font-family:'Montserrat',sans-serif;font-size:18px;font-weight:600">
                    {feature.title} <span class="text-[#9ACF84]">{feature.highlight}</span>
                  </h3>
                  <p class="text-[#0a0a0f]/50" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">{feature.description}</p>
                </div>
              </div>
            ))}

            <div class="reveal delay-4 pl-17">
              <a href={`${base}/contact-us`} class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
                Contact Us
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Consultation form -->
    <ConsultationSection />

  </main>
  <Footer />
</Layout>
