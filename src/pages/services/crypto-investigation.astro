---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ConsultationSection from '../../components/ConsultationSection.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const siteUrl = "https://classick-o.github.io/ScamHelp";

const services = [
  {
    title: "Expert Analysis and Forensic Investigation",
    description: "ScamHelp employs state-of-the-art forensic tools to analyze blockchain transactions, identify fraudulent patterns, and trace the flow of stolen cryptocurrency across multiple wallets and exchanges.",
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
  },
  {
    title: "Asset Recovery",
    description: "Our team leverages specialized skills and industry partnerships for recovering lost or stolen cryptocurrency assets, working alongside legal professionals and law enforcement agencies to maximize your chances of recovery.",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "Regulatory Work Assessment",
    description: "We help you navigate the complex regulatory landscape surrounding cryptocurrency by providing detailed compliance reports, liaising with financial regulators, and ensuring all investigation procedures adhere to current legal frameworks.",
    icon: "M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3",
  },
  {
    title: "Prevention and Education",
    description: "ScamHelp offers comprehensive education and training programs designed to help individuals and organizations recognize cryptocurrency threats, understand common fraud tactics, and implement best practices for protecting their digital assets.",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  },
];

const faqs = [
  {
    q: "What are crypto investigation services?",
    a: "Crypto investigation services specialize in tracking, analyzing, and tracing cryptocurrency transactions on the blockchain. These services help identify fraudulent activities, recover lost or stolen digital assets, and provide detailed forensic reports that can be used for legal proceedings or regulatory compliance."
  },
  {
    q: "How do crypto investigation services work?",
    a: "Our team analyzes blockchain data using specialized software and forensic analysis tools. We trace the movement of cryptocurrency across wallets, exchanges, and mixing services, identifying patterns that indicate fraud, theft, or money laundering. The investigation produces a comprehensive report documenting the flow of funds and identifying the parties involved."
  },
  {
    q: "Who can benefit from crypto investigation services?",
    a: "Individuals who have lost cryptocurrency to scams or theft, businesses that have been victims of crypto fraud, organizations seeking to ensure regulatory compliance, and law enforcement agencies investigating financial crimes can all benefit from professional cryptocurrency investigation services."
  },
  {
    q: "Are cryptocurrency investigation services legal?",
    a: "Yes, cryptocurrency investigation services are entirely legal. Our operations work within established legal frameworks, and we frequently collaborate with law enforcement agencies and regulatory bodies. All investigations are conducted in compliance with applicable laws, and our forensic reports are designed to be admissible as evidence in legal proceedings."
  },
  {
    q: "How long does a blockchain investigation typically take?",
    a: "The duration of a blockchain investigation varies depending on the complexity of the case. Simple transaction tracing may take a few days, while more complex investigations involving multiple wallets, cross-chain transactions, or mixing services can take significantly longer. On average, most investigations are completed within 60 days."
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": `${siteUrl}/services`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Crypto Investigation",
      "item": `${siteUrl}/services/crypto-investigation`
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Cryptocurrency Investigation",
  "provider": {
    "@type": "Organization",
    "name": "ScamHelp",
    "url": siteUrl
  },
  "description": "Professional cryptocurrency investigation services using advanced blockchain forensics to uncover fraudulent activities and recover stolen digital assets.",
  "areaServed": "Worldwide",
  "serviceType": "Blockchain Forensic Investigation"
};
---

<Layout
  title="Crypto Investigation Services — ScamHelp | Blockchain Forensics"
  description="ScamHelp's cryptocurrency investigation services uncover fraudulent activities using advanced blockchain forensics. Expert analysis, asset recovery. Free consultation."
  canonical={`${siteUrl}/services/crypto-investigation`}
>
  <Navbar />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <main class="bg-[#0a0a0f]">

    <!-- ═══════════════════════════════════════════
         1 · HERO  (dark)
    ═══════════════════════════════════════════ -->
    <section class="px-6 text-center" style="padding-top:10rem;padding-bottom:5rem;">
      <div class="max-w-3xl mx-auto">
        <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block reveal" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Crypto Investigation</span>
        <h1 class="text-white mb-5 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:700;line-height:1.1">
          Expert &amp; Legitimate <span class="text-[#9ACF84]">Crypto Investigation</span>
        </h1>
        <p class="text-white/40 max-w-xl mx-auto reveal" style="font-family:'Inter',sans-serif;font-size:16px;line-height:1.7">
          Our certified forensic analysts use advanced blockchain tools to trace, investigate, and help recover your stolen or lost cryptocurrency assets.
        </p>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         2 · SERVICES GRID  (white)
    ═══════════════════════════════════════════ -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/5 rounded-full blur-[150px] pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="text-center mb-14 reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Our Services</span>
          <h2 class="text-[#0a0a0f] mb-4" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            Our Cryptocurrency <span class="text-[#9ACF84]">Fraud Investigations</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          {services.map((service, i) => (
            <div class={`reveal delay-${i + 1} group p-7 rounded-2xl border border-[#e8e8e8] bg-white hover:border-[#9ACF84]/30 hover:shadow-lg transition-all duration-300`}>
              <div class="w-14 h-14 rounded-xl bg-[#9ACF84]/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
                </svg>
              </div>
              <h3 class="text-[#0a0a0f] mb-3" style="font-family:'Montserrat',sans-serif;font-size:18px;font-weight:600">
                {service.title}
              </h3>
              <p class="text-[#0a0a0f]/50" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">{service.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         3 · ABOUT SECTION  (dark, 2 cols)
    ═══════════════════════════════════════════ -->
    <section class="py-16 md:py-24 px-6">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Text -->
        <div>
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-4 block reveal" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">About</span>
          <h2 class="text-white mb-6" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            About Scam <span class="text-[#9ACF84]">Help</span>
          </h2>
          <p class="text-white/45 mb-5" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            ScamHelp is the leading blockchain investigation agency, providing expert cryptocurrency forensic services to individuals, businesses, and law enforcement agencies worldwide. Our team of certified analysts combines deep technical expertise with an unwavering commitment to recovering stolen digital assets and bringing fraudsters to justice.
          </p>

          <h3 class="text-white/70 mb-4" style="font-family:'Montserrat',sans-serif;font-size:16px;font-weight:600">
            How can we assist you?
          </h3>

          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white/45" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">
                <strong class="text-white/70">Immediate Support</strong> &mdash; Our team is available to begin your investigation immediately. We understand the urgency and work around the clock to trace your assets before they can be further laundered.
              </span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white/45" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">
                <strong class="text-white/70">Learn More</strong> &mdash; Explore our resources and educational materials to understand how cryptocurrency fraud works and what preventative steps you can take to protect yourself in the future.
              </span>
            </li>
          </ul>

          <p class="text-white/45 mb-8" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Whether you've been a victim of a rug pull, exchange hack, phishing attack, or investment scam, our experts have the tools and experience to investigate your case and provide actionable results.
          </p>

          <a href={`${base}/contact-us`} class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors btn-scale" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
            Start Your Investigation
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Image placeholder -->
        <div class="reveal from-right rounded-2xl border border-white/5 bg-white/[0.02] overflow-hidden flex items-center justify-center" style="height:400px;">
          <div class="text-center">
            <svg class="w-16 h-16 text-[#9ACF84]/30 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <p class="text-white/20" style="font-size:13px">Image placeholder</p>
          </div>
        </div>

      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         4 · HOW CAN WE HELP  (white, 2 cols)
    ═══════════════════════════════════════════ -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/5 rounded-full blur-[150px] pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Image placeholder -->
        <div class="reveal rounded-2xl border border-[#e8e8e8] bg-[#f8f8f8] overflow-hidden flex items-center justify-center" style="height:450px;">
          <div class="text-center">
            <svg class="w-16 h-16 text-[#9ACF84]/30 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <p class="text-[#0a0a0f]/20" style="font-size:13px">Image placeholder</p>
          </div>
        </div>

        <!-- Text -->
        <div>
          <h2 class="text-[#0a0a0f] mb-6 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            How Can Our Cryptocurrency <span class="text-[#9ACF84]">Investigations</span> Help?
          </h2>
          <p class="text-[#0a0a0f]/50 mb-5" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Cryptocurrency fraud is a rapidly growing threat. From sophisticated phishing schemes and Ponzi structures to rug pulls and exchange manipulations, criminals are constantly evolving their tactics. Without expert blockchain forensics, recovering stolen digital assets can feel impossible.
          </p>
          <p class="text-[#0a0a0f]/50 mb-6" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Our cryptocurrency investigations provide the technical clarity and legal-grade evidence needed to pursue recovery through exchanges, law enforcement, and the judicial system. Here is what we bring to the table:
          </p>

          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[#0a0a0f]/60" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">
                <strong class="text-[#0a0a0f]/80">Comprehensive Transaction Tracing</strong> &mdash; We follow the money across multiple blockchains, wallets, and mixing services to build a complete picture of where your funds went.
              </span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[#0a0a0f]/60" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">
                <strong class="text-[#0a0a0f]/80">Expert Analysis</strong> &mdash; Our certified forensic analysts produce detailed, court-admissible reports that identify perpetrators and support legal action.
              </span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[#0a0a0f]/60" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">
                <strong class="text-[#0a0a0f]/80">Preventative Guidance</strong> &mdash; Beyond investigation, we equip you with the knowledge and security practices to safeguard your digital assets going forward.
              </span>
            </li>
          </ul>

          <a href={`${base}/contact-us`} class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors btn-scale" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
            Get a Free Consultation
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         5 · CTA  (dark, centered)
    ═══════════════════════════════════════════ -->
    <section class="py-16 md:py-24 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-white mb-5 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
          Protect your investments with our <span class="text-[#9ACF84]">cryptocurrency investigations</span>
        </h2>
        <p class="text-white/40 mb-8 max-w-2xl mx-auto" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
          Don't let cryptocurrency fraud go uninvestigated. Our expert team is ready to analyze your case, trace your stolen assets, and provide the evidence you need to take action. The sooner you act, the higher the chances of recovery.
        </p>
        <a href={`${base}/contact-us`} class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors btn-scale" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
          Contact Us Today
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         6 · FAQ  (white, details/summary accordion)
    ═══════════════════════════════════════════ -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/5 rounded-full blur-[150px] pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">

          <!-- Left: heading -->
          <div class="lg:col-span-2 reveal">
            <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">FAQ</span>
            <h2 class="text-[#0a0a0f] mb-5" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
              Frequently Asked <span class="text-[#9ACF84]">Questions</span>
            </h2>
            <p class="text-[#0a0a0f]/50 mb-8" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.75">
              Can't find the answer you're looking for? Reach out to our team and we'll get back to you within 24 hours.
            </p>
            <a href={`${base}/contact-us`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-[#0a0a0f]/10 text-[#0a0a0f]/60 hover:text-[#9ACF84] hover:border-[#9ACF84]/30 transition-all" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
              Contact Us
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>

          <!-- Right: accordion -->
          <div class="lg:col-span-3 space-y-2">
            {faqs.map((faq, i) => (
              <div class={`faq-item reveal delay-${Math.min(i + 1, 6)} border border-[#e8e8e8] rounded-2xl overflow-hidden transition-all duration-300`}>
                <button class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-[#f8f8f8] transition-colors duration-200" type="button" aria-expanded="false">
                  <span class="text-[#0a0a0f]" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600;line-height:1.4">{faq.q}</span>
                  <span class="faq-icon flex-shrink-0 w-7 h-7 rounded-full bg-[#f0f0f0] flex items-center justify-center transition-all duration-300">
                    <svg class="w-3.5 h-3.5 text-[#555] transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </span>
                </button>
                <div class="faq-body" style="max-height:0;overflow:hidden;transition:max-height 0.35s ease, padding 0.35s ease;">
                  <p class="px-6 pb-5 text-[#777]" style="font-size:14px;line-height:1.75">{faq.a}</p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         7 · CONSULTATION + FOOTER
    ═══════════════════════════════════════════ -->
    <ConsultationSection />

  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item   = trigger.closest('.faq-item') as HTMLElement;
      const body   = item.querySelector('.faq-body')   as HTMLElement;
      const icon   = item.querySelector('.faq-icon')   as HTMLElement;
      const svg    = icon.querySelector('svg')          as SVGElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('.faq-item').forEach((other) => {
        if (other !== item) {
          (other.querySelector('.faq-body') as HTMLElement).style.maxHeight = '0';
          other.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
          (other.querySelector('.faq-icon') as HTMLElement).style.background = '#f0f0f0';
          (other.querySelector('.faq-icon svg') as SVGElement)?.style.setProperty('transform', 'rotate(0deg)');
          (other.querySelector('.faq-icon svg') as SVGElement)?.style.setProperty('color', '#555');
          (other as HTMLElement).style.borderColor = '#e8e8e8';
        }
      });

      if (isOpen) {
        body.style.maxHeight = '0';
        trigger.setAttribute('aria-expanded', 'false');
        icon.style.background = '#f0f0f0';
        svg.style.transform = 'rotate(0deg)';
        svg.style.color = '#555';
        item.style.borderColor = '#e8e8e8';
      } else {
        body.style.maxHeight = body.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
        icon.style.background = '#9ACF84';
        svg.style.transform = 'rotate(180deg)';
        svg.style.color = '#0a0a0f';
        item.style.borderColor = 'rgba(154,207,132,0.4)';
      }
    });
  });
</script>
