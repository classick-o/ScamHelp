---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ConsultationSection from '../../components/ConsultationSection.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const siteUrl = "https://classick-o.github.io/ScamHelp";

const services = [
  {
    title: "Tracing Cryptocurrency Transactions",
    description: "Our experts analyze the flow of cryptocurrency transactions to detect irregularities, identify suspicious patterns, and map out the movement of funds across the blockchain.",
    iconPath: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
  },
  {
    title: "Trace Crypto Address",
    description: "We identify and verify cryptocurrency wallet addresses linked to fraudulent activity, providing clear documentation of ownership trails and transaction histories.",
    iconPath: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z",
  },
  {
    title: "Crypto Wallet Investigation",
    description: "A thorough examination of wallets and their associated transactions to uncover hidden connections, reveal fund destinations, and build a comprehensive evidence trail.",
    iconPath: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z",
  },
  {
    title: "Trace Token Crypto",
    description: "We trace specific tokens across multiple blockchains and decentralized platforms, following the path of ERC-20, BEP-20, and other token standards to locate misappropriated assets.",
    iconPath: "M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z",
  },
  {
    title: "Network Crypto Tracing",
    description: "Broad analysis of cryptocurrency movements within entire networks, identifying clusters of related wallets and mapping out complex laundering schemes across exchanges and protocols.",
    iconPath: "M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1",
  },
  {
    title: "Custom Trace Reports",
    description: "Tailored forensic reports based on your specific tracing needs, formatted for legal proceedings, insurance claims, or law enforcement submissions with detailed chain-of-custody documentation.",
    iconPath: "M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  },
];

const helpCards = [
  {
    title: "Fast and Efficient Tracking",
    description: "Our advanced blockchain analytics tools enable rapid transaction tracing, giving you actionable results in the shortest possible timeframe to maximise recovery potential.",
    iconPath: "M13 10V3L4 14h7v7l9-11h-7z",
  },
  {
    title: "Expert Analysis",
    description: "Our team of certified blockchain forensic analysts brings years of experience in cryptocurrency investigations, ensuring accurate and court-admissible findings.",
    iconPath: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  },
  {
    title: "Legal Assistance",
    description: "We work alongside legal professionals and law enforcement agencies to ensure traced evidence is properly documented and can be used to support recovery claims and prosecutions.",
    iconPath: "M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3",
  },
  {
    title: "Preventive Measures",
    description: "Beyond tracing, we provide guidance on securing your crypto assets, identifying red flags in transactions, and implementing best practices to prevent future losses.",
    iconPath: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  },
];

const faqs = [
  {
    q: "What are cryptocurrency tracing services?",
    a: "Cryptocurrency tracing services are specialized tools and methodologies used to track and analyze blockchain transactions. Using advanced forensic software, our analysts follow the flow of digital assets across wallets, exchanges, and protocols to identify the destination of funds and the parties involved.",
  },
  {
    q: "How can crypto tracing help if I've been a victim of a scam?",
    a: "Crypto tracing can help track your stolen assets by mapping the exact path your funds took after leaving your wallet. This evidence can be used to identify the perpetrators, freeze funds on cooperating exchanges, and support legal action or law enforcement investigations aimed at recovering your assets.",
  },
  {
    q: "What information do I need to provide?",
    a: "To begin tracing, we typically need transaction IDs (hashes), the wallet addresses involved, timestamps of transactions, the cryptocurrency type, and any communication records with the fraudulent party. The more information you provide, the more effectively we can trace your funds.",
  },
  {
    q: "Is it possible to recover stolen crypto through tracing?",
    a: "While recovery is not guaranteed in every case, tracing significantly increases the chances of a successful outcome. When traced funds are identified on regulated exchanges, those platforms can be compelled to freeze the assets. Combined with legal action, many victims have successfully recovered a portion or all of their stolen cryptocurrency.",
  },
  {
    q: "Are crypto tracing services legal?",
    a: "Yes, cryptocurrency tracing services are completely legal and are widely used by law enforcement agencies, regulatory bodies, and private sector organizations worldwide. Our methods comply with all applicable laws and our reports are designed to meet evidentiary standards for legal proceedings.",
  },
  {
    q: "How long does it take to trace a cryptocurrency transaction?",
    a: "The timeframe varies depending on the complexity of the case. Simple single-chain transactions can often be traced within a few days, while more complex cases involving multiple blockchains, mixers, or privacy protocols may take several weeks. We provide regular progress updates throughout the investigation.",
  },
  {
    q: "What sets Scam Help aside from other recovery companies?",
    a: "Scam Help distinguishes itself by publicly displaying our qualified team of certified blockchain analysts and legal experts. We maintain full transparency throughout the process, provide detailed forensic reports, and work with a global network of law enforcement and exchange partners to maximise recovery outcomes.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": `${siteUrl}/services`,
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Crypto Tracing",
      "item": `${siteUrl}/services/crypto-tracing`,
    },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Cryptocurrency Tracing Services",
  "provider": {
    "@type": "Organization",
    "name": "ScamHelp",
    "url": siteUrl,
  },
  "description": "Advanced blockchain forensic analysis and cryptocurrency tracing services to track stolen crypto assets and support recovery efforts.",
  "areaServed": "Worldwide",
  "serviceType": "Cryptocurrency Tracing",
};
---

<Layout
  title="Crypto Tracing Services — ScamHelp | Track & Recover Crypto"
  description="ScamHelp's cryptocurrency tracing services use advanced blockchain analytics to track stolen crypto assets. Expert forensic analysis. Free consultation."
  canonical={`${siteUrl}/services/crypto-tracing`}
>
  <Navbar />
  <main class="bg-[#0a0a0f]">

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

    <!-- ═══════════════ 1. Hero (dark) ═══════════════ -->
    <section class="px-6 text-center" style="padding-top:10rem;padding-bottom:5rem;">
      <div class="max-w-3xl mx-auto">
        <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block reveal" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Crypto Tracing</span>
        <h1 class="text-white mb-5 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:700;line-height:1.1">
          Legitimate <span class="text-[#9ACF84]">Crypto Tracing Services</span>
        </h1>
        <p class="text-white/40 max-w-xl mx-auto reveal" style="font-family:'Inter',sans-serif;font-size:16px;line-height:1.7">
          Track cryptocurrency transactions with precision. Our blockchain forensic experts use advanced analytics to trace, document, and help recover your stolen digital assets.
        </p>
      </div>
    </section>

    <!-- ═══════════════ 2. Services Grid (white) ═══════════════ -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/5 rounded-full blur-[150px] pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="text-center mb-14 reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Our Services</span>
          <h2 class="text-[#0a0a0f] mb-4" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            Our Cryptocurrency <span class="text-[#9ACF84]">Tracing Services</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {services.map((service, i) => (
            <div class={`reveal delay-${i + 1} group p-7 rounded-2xl border border-[#e8e8e8] bg-white hover:border-[#9ACF84]/30 hover:shadow-lg transition-all duration-300`}>
              <div class="w-14 h-14 rounded-xl bg-[#9ACF84]/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={service.iconPath} />
                </svg>
              </div>
              <h3 class="text-[#0a0a0f] mb-3" style="font-family:'Montserrat',sans-serif;font-size:18px;font-weight:600">
                {service.title}
              </h3>
              <p class="text-[#0a0a0f]/50" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">{service.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ 3. About Section (dark, 2 cols) ═══════════════ -->
    <section class="py-16 md:py-24 px-6">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Text -->
        <div>
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-4 block reveal" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">About Us</span>
          <h2 class="text-white mb-6" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            About Scam <span class="text-[#9ACF84]">Help</span>
          </h2>
          <p class="text-white/45 mb-5" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Scam Help is a premier crypto tracing company dedicated to helping individuals and businesses recover stolen cryptocurrency. Our team of certified blockchain forensic analysts, anti-fraud specialists, and legal experts combine cutting-edge technology with deep industry knowledge to deliver results.
          </p>
          <h3 class="text-white/70 mb-4" style="font-family:'Montserrat',sans-serif;font-size:16px;font-weight:600">
            How we support you
          </h3>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white/45" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
                <strong class="text-white/70">Immediate Support</strong> — Our team responds swiftly to your case, initiating the tracing process as soon as possible to prevent further movement of stolen assets.
              </span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white/45" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
                <strong class="text-white/70">Learn More</strong> — We educate our clients about cryptocurrency security, helping you understand the blockchain landscape and protect yourself against future scams.
              </span>
            </li>
          </ul>
          <p class="text-white/45 mb-8" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Whether you've lost Bitcoin, Ethereum, USDT, or any other cryptocurrency, our tracing services provide the clarity and evidence you need to pursue recovery.
          </p>
          <a href={`${base}/contact-us`} class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors btn-scale" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
            Get a Free Consultation
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Image placeholder -->
        <div class="reveal from-right rounded-2xl border border-white/5 bg-white/[0.02] overflow-hidden flex items-center justify-center" style="height:400px;">
          <div class="text-center">
            <svg class="w-16 h-16 text-[#9ACF84]/30 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <p class="text-white/20" style="font-size:13px">Image placeholder</p>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════ 4. How Can We Help (white) ═══════════════ -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-[#9ACF84]/4 rounded-full blur-[160px] pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="text-center mb-14 reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Our Approach</span>
          <h2 class="text-[#0a0a0f] mb-4" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            How Can Our <span class="text-[#9ACF84]">Crypto Tracing</span> Services Help
          </h2>
          <p class="text-[#0a0a0f]/50 max-w-3xl mx-auto" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Our comprehensive approach combines state-of-the-art blockchain forensics with expert analysis and legal support, giving you the best possible chance of recovering your stolen cryptocurrency.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {helpCards.map((card, i) => (
            <div class={`reveal delay-${i + 1} group p-7 rounded-2xl border border-[#e8e8e8] bg-white hover:border-[#9ACF84]/30 hover:shadow-lg transition-all duration-300`}>
              <div class="w-14 h-14 rounded-xl bg-[#9ACF84]/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={card.iconPath} />
                </svg>
              </div>
              <h3 class="text-[#0a0a0f] mb-3" style="font-family:'Montserrat',sans-serif;font-size:18px;font-weight:600">
                {card.title}
              </h3>
              <p class="text-[#0a0a0f]/50" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ 5. CTA (dark, centered) ═══════════════ -->
    <section class="py-16 md:py-24 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-white mb-6 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
          Unlock the Power of <span class="text-[#9ACF84]">Crypto Tracing</span> with Scam Help
        </h2>
        <p class="text-white/45 max-w-2xl mx-auto mb-8" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
          Don't let scammers get away with your hard-earned assets. Our expert team is ready to trace your stolen cryptocurrency and build the evidence you need for recovery. Contact us today for a free, confidential consultation.
        </p>
        <a href={`${base}/contact-us`} class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors btn-scale" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
          Start Your Free Consultation
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </section>

    <!-- ═══════════════ 6. FAQ (white, accordion) ═══════════════ -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-[#9ACF84]/4 rounded-full blur-[160px] pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="text-center mb-12 reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">
            Frequently Asked Questions
          </span>
          <h2 class="text-[#0a0a0f] mb-5" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            Have any <span class="text-[#9ACF84]">questions?</span>
          </h2>
          <p class="text-[#777] max-w-xl mx-auto" style="font-size:15px;line-height:1.75">
            Find answers to common questions about our cryptocurrency tracing services below. Need more help? Reach out to our team.
          </p>
        </div>

        <div class="max-w-3xl mx-auto space-y-2">
          {faqs.map((faq, i) => (
            <div class={`faq-item reveal delay-${Math.min(i + 1, 6)} border border-[#e8e8e8] rounded-2xl overflow-hidden transition-all duration-300`}>
              <button
                class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-[#f8f8f8] transition-colors duration-200"
                type="button"
                aria-expanded="false"
              >
                <span class="text-[#0a0a0f]" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600;line-height:1.4">
                  {faq.q}
                </span>
                <span class="faq-icon flex-shrink-0 w-7 h-7 rounded-full bg-[#f0f0f0] flex items-center justify-center transition-all duration-300">
                  <svg class="w-3.5 h-3.5 text-[#555] transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </span>
              </button>
              <div class="faq-body" style="max-height:0;overflow:hidden;transition:max-height 0.35s ease, padding 0.35s ease;">
                <p class="px-6 pb-5 text-[#777]" style="font-size:14px;line-height:1.75">
                  {faq.a}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ 7. Consultation + Footer ═══════════════ -->
    <ConsultationSection />

  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item   = trigger.closest('.faq-item') as HTMLElement;
      const body   = item.querySelector('.faq-body')   as HTMLElement;
      const icon   = item.querySelector('.faq-icon')   as HTMLElement;
      const svg    = icon.querySelector('svg')          as SVGElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all others
      document.querySelectorAll('.faq-item').forEach((other) => {
        if (other !== item) {
          (other.querySelector('.faq-body') as HTMLElement).style.maxHeight = '0';
          other.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
          (other.querySelector('.faq-icon') as HTMLElement).style.background = '#f0f0f0';
          (other.querySelector('.faq-icon svg') as SVGElement)?.style.setProperty('transform', 'rotate(0deg)');
          (other.querySelector('.faq-icon svg') as SVGElement)?.style.setProperty('color', '#555');
          (other as HTMLElement).style.borderColor = '#e8e8e8';
        }
      });

      if (isOpen) {
        body.style.maxHeight = '0';
        trigger.setAttribute('aria-expanded', 'false');
        icon.style.background = '#f0f0f0';
        svg.style.transform = 'rotate(0deg)';
        svg.style.color = '#555';
        item.style.borderColor = '#e8e8e8';
      } else {
        body.style.maxHeight = body.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
        icon.style.background = '#9ACF84';
        svg.style.transform = 'rotate(180deg)';
        svg.style.color = '#0a0a0f';
        item.style.borderColor = 'rgba(154,207,132,0.4)';
      }
    });
  });
</script>
