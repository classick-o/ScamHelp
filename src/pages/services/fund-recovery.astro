---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ConsultationSection from '../../components/ConsultationSection.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const services = [
  {
    title: "Refund Recovery",
    description: "Our specialists handle the recovery of unauthorized transaction refunds. We work directly with banks and financial institutions to ensure a swift and secure recovery process.",
    icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z",
  },
  {
    title: "Scammed Money Recovery",
    description: "We help victims of online scams to get their money back. Our approach involves thorough investigation and collaboration with law enforcement agencies.",
    icon: "M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9",
  },
  {
    title: "Bank Refund Scams",
    description: "Our investigation service offers a thorough examination of bank fraud cases and their associated transactions. We help you understand the movement of funds, uncovering hidden patterns.",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  },
  {
    title: "Online Fraud Refund",
    description: "We specialize in navigating fund recovery and help clients recover money lost to online fraud. Our experts use advanced tools and techniques to trace fraudulent transactions.",
    icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
  {
    title: "Liaison with Financial Institutions",
    description: "Our experts have established relationships with banks, credit card companies, and other financial institutions, allowing us to navigate the complexities of fund recovery efficiently.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  },
  {
    title: "Ongoing Support and Updates",
    description: "We believe in transparent communication. Throughout the recovery process, you'll receive regular updates and have continuous access to our team for any questions.",
    icon: "M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z",
  },
];

const faqs = [
  {
    question: "How does Scam Help identify if my case is eligible for recovery?",
    answer: "We start with a detailed assessment of your case, examining the nature of the scam, the amount lost, transaction details, and communication records.",
  },
  {
    question: "What types of scams can Scam Help assist with?",
    answer: "Our fund recovery services cover a wide range of scenarios including online investment frauds, cryptocurrency scams, credit card fraud, phishing attacks, and more.",
  },
  {
    question: "What should I provide for my initial consultation?",
    answer: "You may prepare any relevant documents and evidence, such as transaction records, correspondence with the scammer, screenshots of interactions.",
  },
  {
    question: "Is there a fee for the initial consultation?",
    answer: "We offer a free initial consultation to discuss the specifics of your case and provide initial guidance.",
  },
  {
    question: "What is the typical success rate of Scam Help's recovery efforts?",
    answer: "While each case is unique, our team has maintained a high success rate, thanks to our specialized knowledge and collaborative approach with international law enforcement agencies.",
  },
  {
    question: "How long does the recovery process take?",
    answer: "The timeline can vary significantly depending on the complexity of the case, the jurisdiction involved, and the responsiveness of financial institutions. Cases can take anywhere from a few weeks to several months.",
  },
  {
    question: "What sets Scam Help aside from other recovery companies?",
    answer: "Most Scam Recovery sites are scams themselves or deliver a poor and slow service. What sets us aside — we publicly display our qualified team members who are distinguished in the field of AML and asset recovery.",
  },
];

const siteUrl = "https://classick-o.github.io/ScamHelp";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": `${siteUrl}/services`,
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Fund Recovery",
      "item": `${siteUrl}/services/fund-recovery`,
    },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Fund Recovery Services",
  "provider": {
    "@type": "Organization",
    "name": "ScamHelp",
    "url": siteUrl,
  },
  "description": "Professional fund recovery services helping victims of online fraud, bank scams, and unauthorized transactions recover their lost money.",
  "areaServed": "Worldwide",
  "serviceType": "Fund Recovery",
};
---

<Layout
  title="Fund Recovery Services — ScamHelp | Recover Lost Funds"
  description="ScamHelp's professional fund recovery services help victims of online fraud, bank scams, and unauthorized transactions recover their lost money. Free consultation available."
>
  <Navbar />
  <main>

    <!-- JSON-LD Schemas -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

    <!-- ═══════════ 1. HERO (dark) ═══════════ -->
    <section class="bg-[#0a0a0f] px-6 text-center" style="padding-top:10rem;padding-bottom:5rem;">
      <div class="max-w-3xl mx-auto">
        <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block reveal" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">Fund Recovery</span>
        <h1 class="text-white mb-5 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:700;line-height:1.1">
          Expert <span class="text-[#9ACF84]">Fund Recovery Services</span>
        </h1>
        <p class="text-white/40 max-w-xl mx-auto reveal" style="font-family:'Inter',sans-serif;font-size:16px;line-height:1.7">
          We help victims of online fraud, banking scams, and unauthorized transactions recover their lost funds through expert strategies and proven recovery methods.
        </p>
      </div>
    </section>

    <!-- ═══════════ 2. SERVICES GRID (white) ═══════════ -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/5 rounded-full blur-[150px] pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="text-center mb-14 reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">What We Offer</span>
          <h2 class="text-[#0a0a0f] mb-4" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            Our Financial <span class="text-[#9ACF84]">Fund Recovery</span> Services
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {services.map((service, i) => (
            <div class={`reveal delay-${i + 1} group p-7 rounded-2xl border border-[#e8e8e8] bg-white hover:border-[#9ACF84]/30 hover:shadow-lg transition-all duration-300`}>
              <div class="w-12 h-12 rounded-xl bg-[#9ACF84]/10 flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
                </svg>
              </div>
              <h3 class="text-[#0a0a0f] mb-3" style="font-family:'Montserrat',sans-serif;font-size:16px;font-weight:600">{service.title}</h3>
              <p class="text-[#0a0a0f]/50" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">{service.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════ 3. ABOUT / LOGO (dark) ═══════════ -->
    <section class="py-16 md:py-24 px-6 bg-[#0a0a0f]">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Text -->
        <div>
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-4 block reveal" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">About Us</span>
          <h2 class="text-white mb-6" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            About Scam <span class="text-[#9ACF84]">Help</span>
          </h2>
          <p class="text-white/45 mb-6" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            ScamHelp is a leading fund recovery company dedicated to helping victims of online scams and financial fraud reclaim their lost assets. With a team of experienced professionals, we specialize in navigating the complex process of recovering funds from fraudulent entities, banks, and financial institutions.
          </p>
          <h3 class="text-white mb-4" style="font-family:'Montserrat',sans-serif;font-size:18px;font-weight:600">
            Why wait? Secure your digital assets today!
          </h3>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white/45" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75"><strong class="text-white/70">Immediate Support</strong> — Our team is ready to assist you from the very first consultation, providing actionable steps to begin your recovery journey.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white/45" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75"><strong class="text-white/70">Learn More</strong> — Explore our comprehensive resources and case studies to understand how we can help you.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white/45" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75"><strong class="text-white/70">Request a Demo</strong> — See our recovery process in action and learn how we can tailor our services to your specific case.</span>
            </li>
          </ul>
          <p class="text-white/45 mb-8" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Don't let scammers get away with your hard-earned money. Take the first step toward recovery today.
          </p>
          <a href={`${base}/about`} class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors btn-scale" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
            Learn More
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Logo placeholder -->
        <div class="reveal from-right rounded-2xl border border-white/5 bg-white/[0.02] overflow-hidden flex items-center justify-center" style="height:450px;">
          <div class="text-center">
            <svg class="w-20 h-20 text-[#9ACF84]/30 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            <p class="text-white/20" style="font-family:'Montserrat',sans-serif;font-size:15px;font-weight:600">ScamHelp Logo</p>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════ 4. HOW CAN WE HELP (white) ═══════════ -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/5 rounded-full blur-[150px] pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Image placeholder -->
        <div class="reveal rounded-2xl border border-[#e8e8e8] bg-[#f8f8f8] overflow-hidden flex items-center justify-center" style="height:450px;">
          <div class="text-center">
            <svg class="w-16 h-16 text-[#9ACF84]/30 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <p class="text-[#0a0a0f]/20" style="font-size:13px">Image Placeholder</p>
          </div>
        </div>

        <!-- Text -->
        <div>
          <h2 class="text-[#0a0a0f] mb-6 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            How Can Scam Help Assist You With <span class="text-[#9ACF84]">Fund Recovery?</span>
          </h2>
          <p class="text-[#0a0a0f]/60 mb-6" style="font-family:'Inter',sans-serif;font-size:15px;line-height:1.8">
            Our dedicated team combines legal expertise, financial knowledge, and cutting-edge technology to maximize your chances of recovering lost funds. We handle every aspect of the recovery process so you can focus on moving forward.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[#0a0a0f]/60" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">Timely communication</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[#0a0a0f]/60" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">Experienced experts</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[#0a0a0f]/60" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">Efficient handling</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#9ACF84] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[#0a0a0f]/60" style="font-family:'Inter',sans-serif;font-size:14px;line-height:1.75">Successful recovery track record</span>
            </li>
          </ul>
          <a href="#consultation" class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors btn-scale" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
            Free Consultation
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

      </div>
    </section>

    <!-- ═══════════ 5. CTA BANNER (dark) ═══════════ -->
    <section class="py-16 md:py-24 px-6 bg-[#0a0a0f]">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-white mb-5 reveal" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
          Ready to Reclaim Your <span class="text-[#9ACF84]">Lost Funds?</span>
        </h2>
        <p class="text-white/40 max-w-xl mx-auto mb-8" style="font-family:'Inter',sans-serif;font-size:16px;line-height:1.7">
          Don't let scammers keep what's rightfully yours. Our team of experts is ready to help you recover your lost funds with a proven, professional approach.
        </p>
        <a href={`${base}/contact-us`} class="inline-flex items-center gap-2 px-6 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors btn-scale" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
          Contact Us
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </section>

    <!-- ═══════════ 6. FAQ (white) ═══════════ -->
    <section class="py-16 md:py-24 px-6 bg-white relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/5 rounded-full blur-[150px] pointer-events-none"></div>

      <div class="relative z-10 max-w-3xl mx-auto">
        <div class="text-center mb-14 reveal">
          <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">FAQ</span>
          <h2 class="text-[#0a0a0f] mb-4" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
            Frequently Asked <span class="text-[#9ACF84]">Questions</span>
          </h2>
        </div>

        <div class="space-y-2">
          {faqs.map((faq, i) => (
            <div class={`faq-item reveal delay-${Math.min(i + 1, 6)} border border-[#e8e8e8] rounded-2xl overflow-hidden transition-all duration-300`}>
              <button class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-[#f8f8f8] transition-colors duration-200" type="button" aria-expanded="false">
                <span class="text-[#0a0a0f]" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600;line-height:1.4">{faq.question}</span>
                <span class="faq-icon flex-shrink-0 w-7 h-7 rounded-full bg-[#f0f0f0] flex items-center justify-center transition-all duration-300">
                  <svg class="w-3.5 h-3.5 text-[#555] transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </span>
              </button>
              <div class="faq-body" style="max-height:0;overflow:hidden;transition:max-height 0.35s ease, padding 0.35s ease;">
                <p class="px-6 pb-5 text-[#777]" style="font-size:14px;line-height:1.75">{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════ 7. CONSULTATION ═══════════ -->
    <ConsultationSection />

  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item   = trigger.closest('.faq-item') as HTMLElement;
      const body   = item.querySelector('.faq-body')   as HTMLElement;
      const icon   = item.querySelector('.faq-icon')   as HTMLElement;
      const svg    = icon.querySelector('svg')          as SVGElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('.faq-item').forEach((other) => {
        if (other !== item) {
          (other.querySelector('.faq-body') as HTMLElement).style.maxHeight = '0';
          other.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
          (other.querySelector('.faq-icon') as HTMLElement).style.background = '#f0f0f0';
          (other.querySelector('.faq-icon svg') as SVGElement)?.style.setProperty('transform', 'rotate(0deg)');
          (other.querySelector('.faq-icon svg') as SVGElement)?.style.setProperty('color', '#555');
          (other as HTMLElement).style.borderColor = '#e8e8e8';
        }
      });

      if (isOpen) {
        body.style.maxHeight = '0';
        trigger.setAttribute('aria-expanded', 'false');
        icon.style.background = '#f0f0f0';
        svg.style.transform = 'rotate(0deg)';
        svg.style.color = '#555';
        item.style.borderColor = '#e8e8e8';
      } else {
        body.style.maxHeight = body.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
        icon.style.background = '#9ACF84';
        svg.style.transform = 'rotate(180deg)';
        svg.style.color = '#0a0a0f';
        item.style.borderColor = 'rgba(154,207,132,0.4)';
      }
    });
  });
</script>
