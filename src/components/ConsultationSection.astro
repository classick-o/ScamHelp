---
const benefits = [
  "Free & confidential assessment",
  "No obligation consultation",
  "Response within 24 hours",
  "Expert case evaluation",
];

const countries   = ["Netherlands","United Kingdom","United States","Germany","France","Spain","Italy","Australia","Canada","Other"];
const scamTypes   = ["Investment Scam","Loan Scam","Romance Scam","Cryptocurrency Scam","Forex Trading Scam","Binary Options Scam","Other"];
const amounts     = ["Below 5,000 EUR","5,000–10,000 EUR","10,000–30,000 EUR","Above 30,000 EUR"];

const inputClasses = "w-full px-4 py-3 bg-[#13131d] border border-white/8 rounded-xl text-white placeholder-white/25 focus:border-[#9ACF84]/50 focus:outline-none focus:ring-1 focus:ring-[#9ACF84]/20 transition-all duration-200";
---

<section id="consultation" class="consultation-section relative py-16 md:py-20">
  <!-- Video background -->
  <video autoplay muted loop playsinline preload="metadata" class="absolute inset-0 z-[0] w-full h-full object-cover pointer-events-none">
    <source src={`${import.meta.env.BASE_URL}/form_section_video.mp4`} type="video/mp4" />
  </video>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Left: info panel -->
      <div class="reveal from-left">
        <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-3 block" style="font-family:'Montserrat',sans-serif;font-size:10px;font-weight:600">
          Get Started
        </span>
        <h2 class="text-white mb-3" style="font-family:'Montserrat',sans-serif;font-size:clamp(22px,2.8vw,34px);font-weight:600;line-height:1.2">
          Get a free consultation to see if you are{" "}
          <span class="text-[#9ACF84]">eligible for a refund</span>
        </h2>
        <p class="text-white/40 mb-6" style="font-size:13px;line-height:1.7">
          Fill out the form to get a free, confidential consultation with our recovery
          specialists. We'll assess your case and advise on the best course of action.
        </p>
        <div class="space-y-2.5">
          {benefits.map((item, i) => (
            <div class={`reveal from-left delay-${i + 2} flex items-center gap-2.5`}>
              <svg class="w-3.5 h-3.5 text-[#9ACF84] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-white/50 text-[12px] md:text-[15px]" style="font-family:'Montserrat',sans-serif">{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Form -->
      <div class="reveal from-right delay-1">
        <form id="consultation-form" class="p-6 md:p-8 rounded-xl bg-[#111119] border border-white/[0.06] space-y-3">

          <!-- Row 1: Name -->
          <div class="grid grid-cols-2 gap-3">
            <input id="f-firstName" type="text" name="firstName" required class={inputClasses} style="font-size:13px" placeholder="First Name*" />
            <input id="f-lastName"  type="text" name="lastName"  required class={inputClasses} style="font-size:13px" placeholder="Last Name*" />
          </div>

          <!-- Row 2: Email -->
          <input id="f-email" type="email" name="email" required class={inputClasses} style="font-size:13px" placeholder="Email Address*" />

          <!-- Row 3: Phone + Country -->
          <div class="grid grid-cols-2 gap-3">
            <input id="f-phone" type="tel" name="phone" required class={inputClasses} style="font-size:13px" placeholder="Phone Number*" />
            <!-- Country dropdown -->
            <div class="cselect" data-name="country">
              <input type="hidden" name="country" class="cselect-value" />
              <button type="button" class="cselect-trigger">
                <span class="cselect-label">Country*</span>
                <svg class="cselect-arrow w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul class="cselect-list">
                {countries.map((c) => <li class="cselect-option" data-value={c}>{c}</li>)}
              </ul>
            </div>
          </div>

          <!-- Row 4: Scam type + Amount -->
          <div class="grid grid-cols-2 gap-3">
            <!-- Scam type dropdown -->
            <div class="cselect" data-name="scamType">
              <input type="hidden" name="scamType" class="cselect-value" />
              <button type="button" class="cselect-trigger">
                <span class="cselect-label">Type of scam*</span>
                <svg class="cselect-arrow w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul class="cselect-list">
                {scamTypes.map((s) => <li class="cselect-option" data-value={s}>{s}</li>)}
              </ul>
            </div>
            <!-- Amount dropdown -->
            <div class="cselect" data-name="amountLost">
              <input type="hidden" name="amountLost" class="cselect-value" />
              <button type="button" class="cselect-trigger">
                <span class="cselect-label">Amount lost*</span>
                <svg class="cselect-arrow w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul class="cselect-list">
                {amounts.map((a) => <li class="cselect-option" data-value={a}>{a}</li>)}
              </ul>
            </div>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="btn-scale w-full flex items-center justify-center gap-2 px-8 py-3.5 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors duration-200 mt-1"
            style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" />
            </svg>
            Submit
          </button>

          <p class="text-white/20 text-center" style="font-size:11px">
            Your information is confidential and secure.
          </p>

        </form>
      </div>

    </div>
  </div>
</section>

<script>
  // Custom select logic
  document.querySelectorAll('.cselect').forEach((sel) => {
    const trigger = sel.querySelector('.cselect-trigger') as HTMLElement;
    const list    = sel.querySelector('.cselect-list')    as HTMLElement;
    const label   = sel.querySelector('.cselect-label')   as HTMLElement;
    const hidden  = sel.querySelector('.cselect-value')   as HTMLInputElement;
    const arrow   = sel.querySelector('.cselect-arrow')   as HTMLElement;

    list.addEventListener('wheel', (e) => {
      e.preventDefault();
      e.stopPropagation();
      list.scrollTop += e.deltaY;
    }, { passive: false });

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = sel.classList.contains('open');
      document.querySelectorAll('.cselect.open').forEach((s) => s.classList.remove('open'));
      if (!isOpen) sel.classList.add('open');
    });


    sel.querySelectorAll('.cselect-option').forEach((opt) => {
      opt.addEventListener('click', () => {
        const val = (opt as HTMLElement).dataset.value || '';
        hidden.value = val;
        label.textContent = val;
        label.style.color = 'rgba(255,255,255,0.85)';
        sel.querySelectorAll('.cselect-option').forEach((o) => o.classList.remove('active'));
        opt.classList.add('active');
        sel.classList.remove('open');
      });
    });
  });

  // Close on outside click — only if target is outside the dropdown
  document.addEventListener('click', (e) => {
    document.querySelectorAll('.cselect.open').forEach((s) => {
      if (!s.contains(e.target as Node)) {
        s.classList.remove('open');
      }
    });
  });

  // Form submit
  document.getElementById('consultation-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = {
      firstName: (document.getElementById('f-firstName') as HTMLInputElement)?.value,
      lastName:  (document.getElementById('f-lastName')  as HTMLInputElement)?.value,
      email:     (document.getElementById('f-email')     as HTMLInputElement)?.value,
      phone:     (document.getElementById('f-phone')     as HTMLInputElement)?.value,
      country:   (document.querySelector('[name="country"].cselect-value')   as HTMLInputElement)?.value,
      scamType:  (document.querySelector('[name="scamType"].cselect-value')  as HTMLInputElement)?.value,
      amountLost:(document.querySelector('[name="amountLost"].cselect-value') as HTMLInputElement)?.value,
    };
    console.log('Form submission object:', formData);
  });
</script>

<style>
  /* Section overlay via pseudo-element — immune to child reveal transitions */
  .consultation-section {
    background: #0a0a0f;
    overflow: hidden;
  }
  .consultation-section::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(10,10,15,0.88);
    pointer-events: none;
  }
  .consultation-section > .relative {
    z-index: 2;
  }

  /* Custom select */
  .cselect {
    position: relative;
  }
  .cselect-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 12px 16px;
    background: #13131d;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    cursor: pointer;
    transition: border-color 0.2s;
    text-align: left;
  }
  .cselect-trigger:hover,
  .cselect.open .cselect-trigger {
    border-color: rgba(154,207,132,0.5);
  }
  .cselect-label {
    font-size: 13px;
    color: rgba(255,255,255,0.25);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cselect-arrow {
    color: rgba(255,255,255,0.25);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .cselect.open .cselect-arrow {
    transform: rotate(180deg);
  }

  .cselect-list {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: #1a1a28;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    max-height: 190px;
    overflow-y: scroll;
    z-index: 100;
    list-style: none;
    margin: 0;
    padding: 4px;
  }
  .cselect.open .cselect-list {
    display: block;
  }
  .cselect-option {
    padding: 9px 12px;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }
  .cselect-list::-webkit-scrollbar { width: 4px; }
  .cselect-list::-webkit-scrollbar-track { background: transparent; }
  .cselect-list::-webkit-scrollbar-thumb { background: rgba(154,207,132,0.2); border-radius: 4px; }
  .cselect-list::-webkit-scrollbar-thumb:hover { background: rgba(154,207,132,0.4); }

  .cselect-option:hover {
    background: rgba(154,207,132,0.08);
    color: rgba(255,255,255,0.9);
  }
  .cselect-option.active {
    background: rgba(154,207,132,0.12);
    color: #9ACF84;
  }
</style>
