---
const scamTypes = [
  {
    title: "Investment Scam",
    description: "Fraudulent schemes promising high returns on fake investment platforms.",
    iconPath: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6",
  },
  {
    title: "Loan Scam",
    description: "Fake lenders collecting upfront fees with no intention of providing funds.",
    iconPath: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "Romance Scam",
    description: "Criminals building fake relationships online to extort money from victims.",
    iconPath: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
  },
  {
    title: "Cryptocurrency Scam",
    description: "Fake exchanges and rug pulls targeting crypto investors worldwide.",
    iconPath: "M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z",
  },
  {
    title: "Forex Trading Scam",
    description: "Unregulated brokers manipulating trades and blocking fund withdrawals.",
    iconPath: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
  },
  {
    title: "Binary Options Scam",
    description: "Illegal platforms rigging binary outcomes to ensure traders always lose.",
    iconPath: "M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
  },
];
---

<section id="scams" class="py-16 md:py-24 bg-[#0a0a0f] relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#9ACF84]/3 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Heading -->
    <div class="reveal text-center mb-16">
      <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">
        Common Scams
      </span>
      <h2 class="text-white mb-4" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
        We Handle <span class="text-[#9ACF84]">Every Type</span> of Scam
      </h2>
      <p class="text-white/40 max-w-xl mx-auto" style="font-size:15px;line-height:1.8">
        No matter what type of scam you've been affected by, our team has the expertise to help you recover.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {scamTypes.map((scam, i) => (
        <div class={`reveal delay-${i + 1} group relative pt-6 px-6 pb-4 rounded-2xl border border-white/5 bg-white/[0.02] hover:border-[#9ACF84]/25 hover:bg-white/[0.04] transition-all duration-300 cursor-pointer overflow-hidden`}>

          <!-- Number (bottom-right, spilling 15% outside) -->
          <span class="absolute text-white/[0.06]" style="font-family:'Montserrat',sans-serif;font-size:80px;font-weight:800;line-height:1;letter-spacing:-0.04em;bottom:-10px;right:-10px;">
            {String(i + 1).padStart(2, '0')}
          </span>

          <!-- Icon + Title row -->
          <div class="flex items-center gap-3 mb-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-[#9ACF84]/8 flex items-center justify-center group-hover:bg-[#9ACF84]/15 transition-colors duration-200">
              <svg class="w-5 h-5 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d={scam.iconPath} />
              </svg>
            </div>
            <h3 class="text-white" style="font-family:'Montserrat',sans-serif;font-size:17px;font-weight:600;line-height:1.2">
              {scam.title}
            </h3>
          </div>

          <!-- Description -->
          <p class="text-white/35" style="font-size:13px;line-height:1.65">
            {scam.description}
          </p>

          <!-- Bottom arrow -->
          <div class="mt-4 flex items-center gap-1.5 text-[#9ACF84]/0 group-hover:text-[#9ACF84] transition-colors duration-200">
            <span style="font-family:'Montserrat',sans-serif;font-size:12px;font-weight:600">Learn more</span>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
