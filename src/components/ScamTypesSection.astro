---
const scamTypes = [
  "Investment Scam",
  "Loan Scam",
  "Romance Scam",
  "Cryptocurrency Scam",
  "Forex Trading Scam",
  "Binary Options Scam",
];
---

<section id="scams" class="py-16 md:py-20 bg-[#0a0a0f] relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
  <div class="absolute top-1/3 right-0 w-[400px] h-[400px] bg-[#9ACF84]/3 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">

      <!-- Image -->
      <div class="reveal from-scale order-2 lg:order-1 relative">
        <div class="rounded-xl overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1590286162167-70fb467846ae?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjcnlwdG9jdXJyZW5jeSUyMGJsb2NrY2hhaW4lMjB0ZWNobm9sb2d5fGVufDF8fHx8MTc3MjQ0MzgxNXww&ixlib=rb-4.1.0&q=80&w=1080"
            alt="Cryptocurrency blockchain technology"
            class="w-full h-[480px] object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0f] via-transparent to-transparent rounded-xl"></div>
        </div>
      </div>

      <!-- List -->
      <div class="reveal from-right delay-1 order-1 lg:order-2">
        <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">
          Common Scams
        </span>
        <h2 class="text-white mb-6" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
          We Handle{" "}
          <span class="text-[#9ACF84] italic">Every Type</span>{" "}
          of Scam
        </h2>
        <p class="text-white/40 mb-8" style="font-size:15px;line-height:1.8">
          No matter what type of scam you've been affected by, our team has the
          experience and expertise to help you recover your funds.
        </p>

        <div class="space-y-2.5">
          {scamTypes.map((scam, i) => (
            <div class={`reveal delay-${i + 2} flex items-center justify-between p-4 rounded-xl bg-white/[0.03] border border-white/5 hover:border-[#9ACF84]/15 hover:bg-white/[0.05] transition-all duration-200 group cursor-pointer`}>
              <div class="flex items-center gap-3.5">
                <div class="w-9 h-9 rounded-lg bg-[#9ACF84]/8 flex items-center justify-center group-hover:bg-[#9ACF84]/12 transition-colors">
                  <!-- AlertTriangle icon -->
                  <svg class="w-4 h-4 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4m0 4h.01" />
                  </svg>
                </div>
                <span class="text-white/80" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:500">
                  {scam}
                </span>
              </div>
              <!-- ArrowRight -->
              <svg class="w-4 h-4 text-white/15 group-hover:text-[#9ACF84] transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
