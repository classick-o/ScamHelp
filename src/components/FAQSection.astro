---
const faqs = [
  {
    q: "How do I know if I've been a victim of a crypto scam?",
    a: "Signs of a crypto scam include unexpected requests for money transfers in cryptocurrency, promises of high returns with no risk, unsolicited offers from strangers, and platforms or exchanges that refuse withdrawals or lack transparency. If you encounter these red flags, you might be dealing with a scam.",
  },
  {
    q: "What should I do immediately after suspecting a crypto scam?",
    a: "Immediately stop all communications with the scammer. Do not send any more cryptocurrency, and secure your remaining assets by transferring them to a new wallet. Collect all documentation related to the scam, such as emails, wallet addresses, and transaction histories, and report the incident to us and relevant authorities.",
  },
  {
    q: "Can Scam Help recover my stolen cryptocurrency?",
    a: "While we cannot guarantee recovery of all stolen assets, our online fraud help works with a network of cybersecurity experts and legal professionals to trace and attempt to recover stolen cryptocurrency. The success of recovery efforts largely depends on the specifics of the scam and the promptness of the response.",
  },
  {
    q: "What types of crypto scams does Scam Help assist with?",
    a: "We assist with a variety of crypto scams, including phishing attacks, fake ICOs (Initial Coin Offerings), Ponzi schemes, fake crypto exchanges, and wallet hacks. Our team is knowledgeable about the latest scam tactics and provides tailored advice for each scenario.",
  },
  {
    q: "How long does the recovery process take?",
    a: "The recovery process can vary greatly depending on the complexity of the scam and the actions taken by the scammer. Recovery efforts can take anywhere from a few months to an average of 6 months. We strive to act swiftly and keep you informed throughout the process.",
  },
];
---

<section class="pt-16 md:pt-24 pb-4 bg-white relative overflow-hidden">
  <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-[#9ACF84]/4 rounded-full blur-[160px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Centered heading -->
    <div class="reveal text-center mb-12">
      <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">
        Frequently Asked Questions
      </span>
      <h2 class="text-[#0a0a0f] mb-5" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
        Have any <span class="text-[#6BA055]">questions?</span>
      </h2>
      <p class="text-[#777] max-w-xl mx-auto" style="font-size:15px;line-height:1.75">
        Can't find the answer you're looking for? Reach out to our team and we'll get back to you within 24 hours.
      </p>
    </div>

    <!-- Accordion -->
    <div class="reveal max-w-3xl mx-auto space-y-2">
      {faqs.map((faq, i) => (
          <div class={`faq-item reveal delay-${i + 1} border border-[#e8e8e8] rounded-2xl overflow-hidden transition-all duration-300`}>
            <button
              class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-[#f8f8f8] transition-colors duration-200"
              type="button"
              aria-expanded="false"
            >
              <span class="text-[#0a0a0f]" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600;line-height:1.4">
                {faq.q}
              </span>
              <span class="faq-icon flex-shrink-0 w-7 h-7 rounded-full bg-[#f0f0f0] flex items-center justify-center transition-all duration-300">
                <svg class="w-3.5 h-3.5 text-[#555] transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </button>
            <div class="faq-body" style="max-height:0;overflow:hidden;transition:max-height 0.35s ease, padding 0.35s ease;">
              <p class="px-6 pb-5 text-[#777]" style="font-size:14px;line-height:1.75">
                {faq.a}
              </p>
            </div>
          </div>
        ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item   = trigger.closest('.faq-item') as HTMLElement;
      const body   = item.querySelector('.faq-body')   as HTMLElement;
      const icon   = item.querySelector('.faq-icon')   as HTMLElement;
      const svg    = icon.querySelector('svg')          as SVGElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all others
      document.querySelectorAll('.faq-item').forEach((other) => {
        if (other !== item) {
          (other.querySelector('.faq-body') as HTMLElement).style.maxHeight = '0';
          other.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
          (other.querySelector('.faq-icon') as HTMLElement).style.background = '#f0f0f0';
          (other.querySelector('.faq-icon svg') as SVGElement)?.style.setProperty('transform', 'rotate(0deg)');
          (other.querySelector('.faq-icon svg') as SVGElement)?.style.setProperty('color', '#555');
          other.querySelector('.faq-item')?.classList.remove('open');
        }
      });

      if (isOpen) {
        body.style.maxHeight = '0';
        trigger.setAttribute('aria-expanded', 'false');
        icon.style.background = '#f0f0f0';
        svg.style.transform = 'rotate(0deg)';
        svg.style.color = '#555';
        item.style.borderColor = '#e8e8e8';
      } else {
        body.style.maxHeight = body.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
        icon.style.background = '#9ACF84';
        svg.style.transform = 'rotate(180deg)';
        svg.style.color = '#0a0a0f';
        item.style.borderColor = 'rgba(154,207,132,0.4)';
      }
    });
  });
</script>
