---
const items = [
  { label: "Investment fraud victims", icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" },
  { label: "Crypto & NFT scam victims", icon: "M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" },
  { label: "Romance scam victims", icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" },
  { label: "Forex & binary options fraud", icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" },
  { label: "Loan & advance-fee scam victims", icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
  { label: "Online shopping & phishing fraud", icon: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" },
];
---

<section class="py-16 md:py-24 bg-white relative overflow-hidden">
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[#9ACF84]/4 rounded-full blur-[160px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Centered heading -->
    <div class="reveal text-center mb-12">
      <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">
        Our Clients
      </span>
      <h2 class="text-[#0a0a0f] mb-5" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
        Who can <span class="text-[#6BA055]">we help?</span>
      </h2>
      <p class="text-[#777] max-w-2xl mx-auto mb-8" style="font-size:15px;line-height:1.8">
        If you're a victim of online fraud, you're not alone. Scam Help specializes in recovering assets lost to various online financial frauds. We craft winning strategies tailored to our client's needs and budget.
      </p>
      <a
        href="#consultation"
        class="btn-scale inline-flex items-center gap-2 px-7 py-3.5 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors duration-200"
        style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600"
      >
        Get in touch
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>

    <!-- Cards grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {items.map((item, i) => (
        <div class={`reveal delay-${i + 1} flex items-center gap-3 p-4 rounded-2xl border border-[#e8e8e8] bg-white hover:border-[#9ACF84]/40 hover:shadow-sm transition-all duration-200`}>
          <div class="flex-shrink-0 w-9 h-9 rounded-xl bg-[#9ACF84]/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-[#6BA055]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
            </svg>
          </div>
          <span class="text-[#333]" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:500;line-height:1.3">
            {item.label}
          </span>
        </div>
      ))}
    </div>

  </div>
</section>
