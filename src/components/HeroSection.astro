---
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden" style="background:#0a0a0f;">

  <!-- 3D canvas — full section background -->
  <div id="logo-3d" class="absolute inset-0 z-[1] pointer-events-none"></div>

  <!-- Grid pattern overlay (above canvas) -->
  <div class="absolute inset-0 z-[2] pointer-events-none"
    style="opacity:0.028;background-image:linear-gradient(rgba(154,207,132,0.5) 1px,transparent 1px),linear-gradient(90deg,rgba(154,207,132,0.5) 1px,transparent 1px);background-size:60px 60px;"></div>

  <!-- Mouse-tracking glow overlay (above canvas) -->
  <div id="hero-glow" class="absolute inset-0 z-[2] pointer-events-none"
    style="background:radial-gradient(900px circle at 50% 50%,rgba(154,207,132,0.05),transparent 60%);"></div>

  <!-- Loading spinner (right half, visible until GLB loads) -->
  <div id="logo-3d-loader"
    class="absolute z-[3] hidden lg:flex items-center justify-center pointer-events-none"
    style="top:0;right:0;bottom:0;width:50%;">
    <div class="w-10 h-10 rounded-full border-2 border-[#9ACF84]/20 border-t-[#9ACF84]"
      style="animation:spin3d 1s linear infinite;"></div>
  </div>

  <!-- Text content — above canvas -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-32 pb-20 w-full">
    <div class="max-w-xl">

      <h1 class="mb-5 reveal"
        style="font-family:'Montserrat',sans-serif;font-weight:700;line-height:1.05;letter-spacing:-0.03em;font-size:clamp(42px,6vw,72px);transition-delay:0.35s">
        <span class="text-[#9ACF84]">Scam Help</span><br />
        <span class="text-white">To The Rescue</span>
      </h1>

      <h2 class="text-white/70 mb-7 reveal"
        style="font-family:'Montserrat',sans-serif;font-weight:500;line-height:1.3;font-size:clamp(18px,2.5vw,26px);transition-delay:0.45s">
        Get Back What Is <span class="text-[#9ACF84] italic">Rightfully</span> Yours!
      </h2>

      <p class="text-white/45 max-w-lg mb-10 reveal" style="font-size:15px;line-height:1.75;transition-delay:0.55s">
        Our expertise spans diverse sectors, from crypto trading to consumer protection.
        If you've fallen victim to any scam, our scam victim support is here to assist
        you in getting back what is rightfully yours.
      </p>

      <div class="flex flex-wrap gap-4 mb-12 reveal" style="transition-delay:0.65s">
        <a href="#about"
          class="btn-scale inline-flex items-center gap-2 px-7 py-3.5 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors duration-200"
          style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600">
          Learn more
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a href="#consultation"
          class="btn-scale inline-flex items-center gap-2 px-7 py-3.5 border border-white/[0.12] text-white rounded-xl hover:bg-white/5 transition-all duration-200"
          style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:500">
          Contact Us
        </a>
      </div>

      <!-- Trust bar -->
      <div class="flex items-center gap-6 flex-wrap reveal" style="transition-delay:0.9s">
        <span class="text-white/25"
          style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase">
          Trusted by
        </span>
        <div class="flex items-center gap-5">
          <div>
            <span class="text-[#9ACF84]" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:700">750+</span>
            <span class="text-white/30 ml-1.5" style="font-family:'Montserrat',sans-serif;font-size:11px">Clients</span>
          </div>
          <div class="w-px h-4 bg-white/10"></div>
          <div class="pl-2">
            <span class="text-[#9ACF84]" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:700">60+</span>
            <span class="text-white/30 ml-1.5" style="font-family:'Montserrat',sans-serif;font-size:11px">Countries</span>
          </div>
          <div class="w-px h-4 bg-white/10"></div>
          <div class="pl-2">
            <span class="text-[#9ACF84]" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:700">24/7</span>
            <span class="text-white/30 ml-1.5" style="font-family:'Montserrat',sans-serif;font-size:11px">Support</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce-y">
    <svg class="w-5 h-5 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>

</section>

<style>
  @keyframes spin3d { to { transform: rotate(360deg); } }
</style>

<script>
  import * as THREE from 'three';
  import { GLTFLoader }      from 'three/addons/loaders/GLTFLoader.js';
  import { RoomEnvironment }  from 'three/addons/environments/RoomEnvironment.js';
  import { EffectComposer }  from 'three/addons/postprocessing/EffectComposer.js';
  import { RenderPass }      from 'three/addons/postprocessing/RenderPass.js';
  import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
  import { ShaderPass }      from 'three/addons/postprocessing/ShaderPass.js';

  const section   = document.getElementById('hero')     as HTMLElement;
  const container = document.getElementById('logo-3d')  as HTMLElement;
  const loaderEl  = document.getElementById('logo-3d-loader') as HTMLElement;
  if (!container) throw new Error('missing #logo-3d');

  const W = section.offsetWidth;
  const H = section.offsetHeight;

  // ── Renderer ──────────────────────────────────────────────────────────────
  const renderer = new THREE.WebGLRenderer({ antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(W, H);
  renderer.outputColorSpace = THREE.SRGBColorSpace;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.0;
  container.appendChild(renderer.domElement);

  // ── Scene & Camera ────────────────────────────────────────────────────────
  const scene = new THREE.Scene();
  scene.background = new THREE.Color(0x0a0a0f);

  const CAM_Z  = 5.5;
  const camera = new THREE.PerspectiveCamera(45, W / H, 0.1, 100);
  camera.position.set(0, 0, CAM_Z);

  // Logo X offset — center of the right half, adaptive to aspect ratio
  const halfH_u = Math.tan((22.5 * Math.PI) / 180) * CAM_Z; // ≈ 2.28
  const LOGO_X  = Math.min(halfH_u * (W / H) * 0.48, 2.8);

  // Glob center depth (behind logo so particles render behind it)
  const GLOBE_Z = -6;

  // Globe X compensat perspectiv: globul e la GLOBE_Z, logo la z=0.
  // Pentru a proiecta pe același pixel X, trebuie scalat cu (CAM_Z - GLOBE_Z) / CAM_Z.
  const GLOBE_X = LOGO_X * (CAM_Z - GLOBE_Z) / CAM_Z;

  // ── Env map (subtle reflections on logo) ─────────────────────────────────
  const pmrem = new THREE.PMREMGenerator(renderer);
  scene.environment = pmrem.fromScene(new RoomEnvironment(0.3)).texture;
  pmrem.dispose();

  // ── Lighting ──────────────────────────────────────────────────────────────
  scene.add(new THREE.AmbientLight(0x9acf84, 0.15));
  const keyLight = new THREE.DirectionalLight(0x9acf84, 0.7);
  keyLight.position.set(3, 4, 5);
  scene.add(keyLight);
  const fillLight = new THREE.DirectionalLight(0xaaddff, 0.15);
  fillLight.position.set(-3, 2, -4);
  scene.add(fillLight);

  // ── Load .glb model ───────────────────────────────────────────────────────
  let pivot: THREE.Group | null = null;

  new GLTFLoader().load('/scamHelp-logo.glb', (gltf) => {
    const model  = gltf.scene;
    const box    = new THREE.Box3().setFromObject(model);
    const center = box.getCenter(new THREE.Vector3());
    const size   = box.getSize(new THREE.Vector3());
    model.position.sub(center);

    const targetScale = 1.7 / Math.max(size.x, size.y, size.z);
    pivot = new THREE.Group();
    pivot.scale.setScalar(0);
    pivot.add(model);

    model.traverse((child) => {
      if ((child as THREE.Mesh).isMesh) {
        (child as THREE.Mesh).material = new THREE.MeshStandardMaterial({
          color:           new THREE.Color(0x9ACF84),
          metalness:       0.35,
          roughness:       0.40,
          envMapIntensity: 0.6,
        });
      }
    });

    scene.add(pivot);
    if (loaderEl) loaderEl.style.display = 'none';

    // Ease-in scale animation on load
    let entT = 0;
    const enter = () => {
      entT = Math.min(entT + 0.02, 1);
      pivot!.scale.setScalar(targetScale * (1 - Math.pow(1 - entT, 3)));
      if (entT < 1) requestAnimationFrame(enter);
    };
    requestAnimationFrame(enter);
  });

  // ── Orbital particle globe ────────────────────────────────────────────────
  // Particles orbit on tilted circular paths, forming a globe centered
  // behind the logo (negative Z so logo always renders in front).
  const PCOUNT  = 900;
  const GLOBE_R = 3.0;  // orbit radius (world units)
  // GLOBE_Z and GLOBE_X already defined above (perspective-corrected)

  const pIncl    = new Float32Array(PCOUNT); // orbit inclination (0..PI)
  const pAscNode = new Float32Array(PCOUNT); // ascending node angle (0..2PI)
  const pOrbitR  = new Float32Array(PCOUNT); // per-particle orbit radius (slight variation)
  const pPhase   = new Float32Array(PCOUNT); // initial angle offset
  const pSpd     = new Float32Array(PCOUNT); // angular speed, mix CW & CCW
  const pDispX   = new Float32Array(PCOUNT); // current smooth displacement X (mouse effect)
  const pDispY   = new Float32Array(PCOUNT); // current smooth displacement Y
  const pCur     = new Float32Array(PCOUNT * 3);

  for (let i = 0; i < PCOUNT; i++) {
    pIncl[i]    = Math.acos(2 * Math.random() - 1); // uniform sphere distribution
    pAscNode[i] = Math.random() * Math.PI * 2;
    pOrbitR[i]  = GLOBE_R * (0.88 + Math.random() * 0.12);
    pPhase[i]   = Math.random() * Math.PI * 2;
    pSpd[i]     = (0.04 + Math.random() * 0.08) * (Math.random() < 0.5 ? 1 : -1);
  }

  const pGeo = new THREE.BufferGeometry();
  pGeo.setAttribute('position', new THREE.BufferAttribute(pCur, 3));
  const pMat = new THREE.PointsMaterial({
    color: 0x9acf84, size: 0.065, transparent: true, opacity: 0.72,
    sizeAttenuation: true, depthWrite: false,
  });
  scene.add(new THREE.Points(pGeo, pMat));

  // ── Selective bloom setup ─────────────────────────────────────────────────
  // bloomComposer: renders scene with logo darkened → applies bloom → to texture
  // finalComposer: renders full scene normally → mixes bloom texture on top
  // Result: particles glow, logo stays clean.

  const bloomComposer = new EffectComposer(renderer);
  bloomComposer.renderToScreen = false;
  bloomComposer.addPass(new RenderPass(scene, camera));
  bloomComposer.addPass(new UnrealBloomPass(
    new THREE.Vector2(W, H),
    1.2,   // strength
    0.5,   // radius
    0.0,   // threshold — everything visible blooms (logo will be blacked out)
  ));

  const MixShader = {
    uniforms: {
      baseTexture:  { value: null },
      bloomTexture: { value: bloomComposer.renderTarget2.texture },
    },
    vertexShader: `
      varying vec2 vUv;
      void main() { vUv = uv; gl_Position = projectionMatrix * modelViewMatrix * vec4(position,1.0); }
    `,
    fragmentShader: `
      uniform sampler2D baseTexture;
      uniform sampler2D bloomTexture;
      varying vec2 vUv;
      void main() {
        gl_FragColor = texture2D(baseTexture, vUv) + vec4(1.0) * texture2D(bloomTexture, vUv);
      }
    `,
  };
  const finalComposer = new EffectComposer(renderer);
  finalComposer.addPass(new RenderPass(scene, camera));
  const mixPass = new ShaderPass(new THREE.ShaderMaterial(MixShader), 'baseTexture');
  mixPass.needsSwap = true;
  finalComposer.addPass(mixPass);

  // Darken logo meshes to black so they don't contribute to bloom
  const _darkMat = new THREE.MeshBasicMaterial({ color: 0x000000 });
  const _savedMats = new Map<THREE.Mesh, THREE.Material | THREE.Material[]>();
  function darkenLogo() {
    if (!pivot) return;
    pivot.traverse((obj) => {
      const m = obj as THREE.Mesh;
      if (m.isMesh) { _savedMats.set(m, m.material); m.material = _darkMat; }
    });
  }
  function restoreLogo() {
    _savedMats.forEach((mat, m) => { m.material = mat; });
    _savedMats.clear();
  }

  // Pre-allocated vectors (avoid GC pressure in render loop)
  const _ndc   = new THREE.Vector3();
  const _dir   = new THREE.Vector3();
  const mWorld = new THREE.Vector3();

  // ── Mouse tracking (full section — canvas is pointer-events:none) ─────────
  let mx = 0, my = 0, mouseOver = false;
  const heroGlow = document.getElementById('hero-glow') as HTMLElement | null;

  section.addEventListener('mousemove', (e) => {
    const rect = section.getBoundingClientRect();
    const rx = (e.clientX - rect.left) / rect.width;
    const ry = (e.clientY - rect.top)  / rect.height;
    mx = (rx - 0.5) * 2;  // NDC -1..1
    my = (ry - 0.5) * 2;
    mouseOver = true;

    // Shift CSS glow to follow cursor
    if (heroGlow) {
      heroGlow.style.background =
        `radial-gradient(900px circle at ${rx * 100}% ${ry * 100}%,rgba(154,207,132,0.05),transparent 60%)`;
    }
  }, { passive: true });

  section.addEventListener('mouseleave', () => { mouseOver = false; });

  // ── Render loop ───────────────────────────────────────────────────────────
  const clock = new THREE.Clock();

  (function animate() {
    requestAnimationFrame(animate);
    const t = clock.getElapsedTime();

    // Logo: gentle floating + fixed tilt
    if (pivot) {
      pivot.position.x = LOGO_X;
      pivot.position.y = Math.sin(t * 0.8) * 0.091;
      pivot.rotation.y = -0.45;
    }

    // Project mouse NDC → world space point on the GLOBE_Z plane
    if (mouseOver) {
      _ndc.set(mx, -my, 0.5).unproject(camera);
      _dir.copy(_ndc).sub(camera.position).normalize();
      const tp = (GLOBE_Z - camera.position.z) / _dir.z;
      mWorld.copy(camera.position).addScaledVector(_dir, tp);
    }

    // Update particle positions
    const posAttr  = pGeo.attributes.position as THREE.BufferAttribute;
    const HOLE_R   = 1.4;   // hollow-circle radius around cursor
    const LERP_IN  = 0.18;  // flee speed
    const LERP_OUT = 0.10;  // return speed (slower → smoother fill-back)

    for (let i = 0; i < PCOUNT; i++) {
      const angle = pPhase[i] + t * pSpd[i];
      const r     = pOrbitR[i];
      const incl  = pIncl[i];
      const asc   = pAscNode[i];

      const lx = Math.cos(angle) * r;
      const ly = Math.sin(angle) * r;

      // Orbit centered at (GLOBE_X, 0, GLOBE_Z) — perspective-corrected to align with logo
      const orbX = GLOBE_X + lx * Math.cos(asc) - ly * Math.cos(incl) * Math.sin(asc);
      const orbY =          lx * Math.sin(asc) + ly * Math.cos(incl) * Math.cos(asc);
      const orbZ =          ly * Math.sin(incl) + GLOBE_Z;

      // Hollow-circle mouse effect
      let tgtX = 0, tgtY = 0;
      if (mouseOver) {
        const dx    = orbX - mWorld.x;
        const dy    = orbY - mWorld.y;
        const dist2 = dx * dx + dy * dy;
        if (dist2 < HOLE_R * HOLE_R && dist2 > 0.0001) {
          const dist = Math.sqrt(dist2);
          const push = HOLE_R - dist;
          tgtX = (dx / dist) * push;
          tgtY = (dy / dist) * push;
        }
      }

      // Smooth lerp toward target displacement
      const lerp = (tgtX !== 0 || tgtY !== 0) ? LERP_IN : LERP_OUT;
      pDispX[i] += (tgtX - pDispX[i]) * lerp;
      pDispY[i] += (tgtY - pDispY[i]) * lerp;

      posAttr.setXYZ(i, orbX + pDispX[i], orbY + pDispY[i], orbZ);
    }
    posAttr.needsUpdate = true;

    // 1. Bloom pass — logo blacked out so only particles glow
    darkenLogo();
    bloomComposer.render();
    restoreLogo();
    // 2. Final pass — clean scene + bloom mixed in additively
    finalComposer.render();
  })();

  // ── Resize ────────────────────────────────────────────────────────────────
  window.addEventListener('resize', () => {
    const w = section.offsetWidth;
    const h = section.offsetHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
    bloomComposer.setSize(w, h);
    finalComposer.setSize(w, h);
  }, { passive: true });
</script>
