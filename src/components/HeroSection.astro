---
---

<section id="hero" class="relative flex flex-col items-center overflow-hidden" style="background:#0a0a0f;height:clamp(800px, 100vh, 900px);">

  <!-- Background video — fullscreen behind everything -->
  <video
    autoplay
    muted
    loop
    playsinline
    class="absolute inset-0 z-[0] w-full h-full object-cover pointer-events-none"
  >
    <source src="/hero_video.mp4" type="video/mp4" />
  </video>
  <!-- Dark green-tinted overlay -->
  <div class="absolute inset-0 z-[1] pointer-events-none" style="background:linear-gradient(to bottom, rgba(10,10,15,0.95), rgba(15,35,12,0.92), rgba(10,10,15,0.95));"></div>
  <div class="absolute inset-0 z-[1] pointer-events-none" style="background:rgba(154,207,132,0.05);mix-blend-mode:overlay;"></div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 z-[2] pointer-events-none"
    style="opacity:0.028;background-image:linear-gradient(rgba(154,207,132,0.5) 1px,transparent 1px),linear-gradient(90deg,rgba(154,207,132,0.5) 1px,transparent 1px);background-size:60px 60px;"></div>


  <!-- Content — centered column, above video -->
  <div class="relative z-10 flex flex-col items-center text-center w-full max-w-5xl mx-auto px-6 pt-40 pb-10">

    <!-- Logo icon -->
    <div class="mb-10 reveal" style="transition-delay:0.1s">
      <div class="hero-icon-outer">
        <div class="hero-icon-inner">
          <img src="/logo_simple.svg" alt="Scam Help" class="w-11 h-11" style="filter:brightness(0) invert(1);" />
        </div>
      </div>
    </div>

    <!-- Badge -->
    <div class="mb-6 reveal" style="transition-delay:0.2s">
      <span class="inline-flex items-center gap-2 text-white/60" style="font-family:'Inter',sans-serif;font-size:13px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;">
        <span class="w-2 h-2 rounded-full bg-[#9ACF84]"></span>
        Scam Victim Support
      </span>
    </div>

    <!-- Heading -->
    <h1 class="mb-6 reveal"
      style="font-family:'Inter',sans-serif;font-weight:600;line-height:1.08;letter-spacing:-0.035em;font-size:clamp(40px,7vw,86px);transition-delay:0.3s">
      <span class="text-white/90">Get Back What Is</span><br />
      <span class="text-white/90">Rightfully </span><span class="italic text-white/90" style="font-family:'Inter',sans-serif;font-style:italic;">Yours.</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-white/40 max-w-lg mb-10 reveal" style="font-family:'Inter',sans-serif;font-size:16px;line-height:1.6;transition-delay:0.45s">
      Our expertise spans diverse sectors, from crypto trading to consumer protection.
      If you've fallen victim to any scam, we're here to help.
    </p>

    <!-- CTA button -->
    <div class="mb-12 reveal" style="transition-delay:0.55s">
      <a href="#consultation" class="hero-cta">
        <span class="hero-cta-inner" style="font-family:'Inter',sans-serif;font-size:15px;">
          Book A Free Call
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </span>
      </a>
    </div>

    <!-- Trust stats with dividers -->
    <div class="flex items-center gap-6 reveal" style="transition-delay:0.65s">
      <span class="text-white/30" style="font-family:'Inter',sans-serif;font-size:14px;">750+ Clients</span>
      <span class="w-px h-4 bg-white/10"></span>
      <span class="text-white/30" style="font-family:'Inter',sans-serif;font-size:14px;">60+ Countries</span>
      <span class="w-px h-4 bg-white/10"></span>
      <span class="text-white/30" style="font-family:'Inter',sans-serif;font-size:14px;">24/7 Support</span>
    </div>

  </div>


</section>

<style>
  .hero-icon-outer {
    width: 96px;
    height: 96px;
    border-radius: 16px;
    background-color: rgb(6, 7, 12);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      rgba(84, 160, 108, 0.37) 0px 0.707px 0.707px -0.667px,
      rgba(84, 160, 108, 0.36) 0px 1.807px 1.807px -1.333px,
      rgba(84, 160, 108, 0.34) 0px 3.622px 3.622px -2px,
      rgba(84, 160, 108, 0.31) 0px 6.866px 6.866px -2.667px,
      rgba(84, 160, 108, 0.247) 0px 13.647px 13.647px -3.333px,
      rgba(84, 160, 108, 0.094) 0px 30px 30px -4px;
  }

  .hero-icon-inner {
    width: 76px;
    height: 76px;
    border-radius: 10px;
    background-color: rgb(6, 7, 12);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      rgba(87, 154, 132, 0.48) 0px 0.796px 0.796px -0.875px,
      rgba(87, 154, 132, 0.455) 0px 2.415px 2.415px -1.75px,
      rgba(87, 154, 132, 0.4) 0px 6.383px 6.383px -2.625px,
      rgba(87, 154, 132, 0.21) 0px 20px 20px -3.5px;
  }

  .hero-cta {
    padding: 2px;
    border-radius: 15px;
    cursor: pointer;
    transition: 0.3s ease;
    background: linear-gradient(
      to bottom right,
      #9ACF84 0%,
      rgba(154, 207, 132, 0) 30%
    );
    background-color: rgba(154, 207, 132, 0.2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .hero-cta:hover,
  .hero-cta:focus {
    background-color: rgba(154, 207, 132, 0.7);
    box-shadow: 0 0 10px rgba(154, 207, 132, 0.5);
    outline: none;
  }

  .hero-cta-inner {
    padding: 12px 32px;
    border-radius: 13px;
    background-color: #0a0a0f;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: #fff;
    font-weight: 500;
  }
</style>

