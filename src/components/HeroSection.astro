---
const floatingIcons = [
  { x: 10, y: 15, delay: "0.7s", duration: "6s", path: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z", title: "Lock" },
  { x: 80, y: 10, delay: "0.9s", duration: "7s", path: "M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z", title: "Eye" },
  { x: 85, y: 70, delay: "1.1s", duration: "8s", path: "M17.81 4.47c-.08 0-.16-.02-.23-.06C15.66 3.42 14 3 12.01 3c-1.98 0-3.86.47-5.57 1.41-.24.13-.54.04-.68-.2-.13-.24-.04-.55.2-.68C7.82 2.52 9.86 2 12.01 2c2.13 0 3.99.47 6.03 1.52.25.13.34.43.21.67-.09.18-.26.28-.44.28zM3.5 9.72c-.1 0-.2-.03-.29-.09-.23-.16-.28-.47-.12-.7.99-1.4 2.25-2.5 3.75-3.27C9.98 4.04 14 4.05 17.15 6.65c1.5.77 2.76 1.86 3.75 3.25.16.22.11.54-.12.7-.23.16-.54.11-.7-.12-.9-1.26-2.04-2.25-3.39-2.94-2.87-2.45-6.64-2.46-9.53-.01-1.35.69-2.49 1.68-3.4 2.95-.09.14-.24.24-.26.24zM12 13c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm-4 7l4-4 4 4H8z", title: "Fingerprint" },
  { x: 5, y: 75, delay: "1.3s", duration: "6.5s", path: "M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z", title: "Shield" },
];

const dotAngles = [0, 1, 2, 3, 4, 5].map((i) => {
  const angle = (i / 6) * Math.PI * 2;
  const r = 42;
  return {
    left: `${50 + Math.cos(angle) * r}%`,
    top:  `${50 + Math.sin(angle) * r}%`,
    delay: `${i * 0.5}s`,
  };
});
---

<section id="hero" class="relative min-h-screen flex items-center bg-[#0a0a0f] overflow-hidden">

  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1770159116807-9b2a7bb82294?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjeWJlcnNlY3VyaXR5JTIwZGlnaXRhbCUyMHByb3RlY3Rpb24lMjBkYXJrfGVufDF8fHx8MTc3MjQ4MjMyMnww&ixlib=rb-4.1.0&q=80&w=1080"
      alt="Cybersecurity background"
      id="hero-bg"
      class="w-full h-full object-cover opacity-20"
      style="transform: scale(1.1); transition: transform 0.4s ease-out;"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0f] via-[#0a0a0f]/60 to-[#0a0a0f]"></div>
  </div>

  <!-- Grid pattern -->
  <div
    class="absolute inset-0 opacity-[0.03] pointer-events-none"
    style="background-image: linear-gradient(rgba(154,207,132,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(154,207,132,0.3) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <!-- Mouse-tracking glow -->
  <div id="hero-glow" class="absolute inset-0 opacity-40 pointer-events-none" style="background: radial-gradient(800px circle at 50% 50%, rgba(154,207,132,0.06), transparent 50%);"></div>

  <!-- Floating orbs -->
  <div class="absolute top-1/3 right-1/5 w-80 h-80 bg-[#9ACF84]/[0.04] rounded-full blur-[120px] pointer-events-none animate-orb"></div>
  <div class="absolute bottom-1/4 left-1/6 w-96 h-96 bg-[#9ACF84]/[0.03] rounded-full blur-[150px] pointer-events-none animate-orb-rev"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-32 pb-20 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">

      <!-- Left: Text content -->
      <div class="max-w-2xl">
        <h1
          class="mb-5 reveal"
          style="font-family:'Montserrat',sans-serif;font-weight:700;line-height:1.05;letter-spacing:-0.03em;font-size:clamp(42px,6vw,72px);transition-delay:0.35s"
        >
          <span class="text-[#9ACF84]">Scam Help</span><br />
          <span class="text-white">To The Rescue</span>
        </h1>

        <h2
          class="text-white/70 mb-7 reveal"
          style="font-family:'Montserrat',sans-serif;font-weight:500;line-height:1.3;font-size:clamp(18px,2.5vw,26px);transition-delay:0.45s"
        >
          Get Back What Is{" "}
          <span class="text-[#9ACF84] italic">Rightfully</span>{" "}
          Yours!
        </h2>

        <p
          class="text-white/45 max-w-lg mb-10 reveal"
          style="font-size:15px;line-height:1.75;transition-delay:0.55s"
        >
          Our expertise spans diverse sectors, from crypto trading to consumer protection.
          If you've fallen victim to any scam, our scam victim support is here to assist
          you in getting back what is rightfully yours.
        </p>

        <div class="flex flex-wrap gap-4 mb-12 reveal" style="transition-delay:0.65s">
          <a
            href="#about"
            class="btn-scale inline-flex items-center gap-2 px-7 py-3.5 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors duration-200"
            style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600"
          >
            Learn more
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="#consultation"
            class="btn-scale inline-flex items-center gap-2 px-7 py-3.5 border border-white/[0.12] text-white rounded-xl hover:bg-white/5 transition-all duration-200"
            style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:500"
          >
            Contact Us
          </a>
        </div>

        <!-- Trust bar -->
        <div class="flex items-center gap-6 flex-wrap reveal" style="transition-delay:0.9s">
          <span class="text-white/25" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase">
            Trusted by
          </span>
          <div class="flex items-center gap-5">
            {[
              { val: "750+", label: "Clients" },
              { val: "60+",  label: "Countries" },
              { val: "24/7", label: "Support" },
            ].map((item, i) => (
              <div class="flex items-center gap-2">
                {i > 0 && <div class="w-px h-4 bg-white/10"></div>}
                <div class={i > 0 ? "pl-2" : ""}>
                  <span class="text-[#9ACF84]" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:700">{item.val}</span>
                  <span class="text-white/30 ml-1.5" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:400">{item.label}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Visual element -->
      <div class="hidden lg:flex items-center justify-center relative reveal from-scale" style="transition-delay:0.5s">
        <div class="relative w-full max-w-md aspect-square">

          <!-- Outer rotating ring -->
          <div class="absolute inset-0 rounded-full border border-dashed border-white/[0.04] animate-spin-slow"></div>

          <!-- Middle pulsing ring -->
          <div class="absolute inset-8 rounded-full border border-[#9ACF84]/10 animate-pulse-ring"></div>

          <!-- Inner ring -->
          <div class="absolute inset-16 rounded-full border border-[#9ACF84]/[0.06]"></div>

          <!-- Center shield -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="relative animate-float">
              <div class="absolute inset-0 blur-[40px] bg-[#9ACF84]/15 rounded-full scale-150"></div>
              <div class="relative w-28 h-28 rounded-2xl bg-gradient-to-br from-[#9ACF84]/15 to-[#9ACF84]/5 border border-[#9ACF84]/20 flex items-center justify-center backdrop-blur-sm">
                <!-- ShieldCheck icon -->
                <svg class="w-12 h-12 text-[#9ACF84]/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Floating security icons -->
          {floatingIcons.map((fi) => (
            <div
              class="absolute z-10"
              style={`left:${fi.x}%;top:${fi.y}%;animation:icon-enter 0.6s ${fi.delay} both`}
            >
              <div style={`animation:icon-float ${fi.duration} ease-in-out infinite ${fi.delay}`}
                class="w-10 h-10 rounded-xl bg-white/[0.03] border border-white/[0.06] backdrop-blur-sm flex items-center justify-center">
                <svg class="w-4 h-4 text-[#9ACF84]/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={fi.path} />
                </svg>
              </div>
            </div>
          ))}

          <!-- Orbit dots -->
          {dotAngles.map((dot, i) => (
            <div
              class="absolute w-1.5 h-1.5 rounded-full bg-[#9ACF84]/40"
              style={`left:${dot.left};top:${dot.top};animation:dot-pulse 3s ease-in-out infinite;animation-delay:${dot.delay}`}
            ></div>
          ))}

          <!-- Data stream SVG lines -->
          <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 400 400">
            <line x1="60" y1="70"   x2="190" y2="190" stroke="rgba(154,207,132,0.08)" stroke-width="1" stroke-dasharray="400" style="animation:draw-line 4s ease-in-out infinite;animation-delay:0s" />
            <line x1="340" y1="60"  x2="210" y2="190" stroke="rgba(154,207,132,0.08)" stroke-width="1" stroke-dasharray="400" style="animation:draw-line 4s ease-in-out infinite;animation-delay:1s" />
            <line x1="340" y1="310" x2="210" y2="210" stroke="rgba(154,207,132,0.08)" stroke-width="1" stroke-dasharray="400" style="animation:draw-line 4s ease-in-out infinite;animation-delay:2s" />
            <line x1="50" y1="320"  x2="190" y2="210" stroke="rgba(154,207,132,0.08)" stroke-width="1" stroke-dasharray="400" style="animation:draw-line 4s ease-in-out infinite;animation-delay:3s" />
          </svg>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce-y">
    <svg class="w-5 h-5 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>

<script>
  // Mouse parallax on hero background
  const heroBg = document.getElementById('hero-bg') as HTMLImageElement | null;
  const heroGlow = document.getElementById('hero-glow') as HTMLDivElement | null;
  const heroSection = document.getElementById('hero') as HTMLElement | null;

  if (heroSection && heroBg) {
    heroSection.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = heroSection.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top)  / rect.height - 0.5;

      heroBg.style.transform = `translate(${x * 15}px, ${y * 15}px) scale(1.1)`;

      if (heroGlow) {
        heroGlow.style.background = `radial-gradient(800px circle at ${50 + x * 30}% ${50 + y * 30}%, rgba(154,207,132,0.06), transparent 50%)`;
      }
    }, { passive: true });
  }
</script>
