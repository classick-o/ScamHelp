---
const base = import.meta.env.BASE_URL;
const navLinks = [
  { label: "About us",         href: `${base}/about`    },
  { label: "Know your rights", href: `${base}/rights`   },
  { label: "Common Scams",     href: `${base}/scams`    },
  { label: "Our Partners",     href: `${base}/partners` },
  { label: "Services",         href: `${base}/services` },
  { label: "News",             href: `${base}/news`     },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-[56px] lg:h-[72px]">

      <!-- Logo -->
      <a href="#" class="btn-scale flex items-center">
        <img src={`${import.meta.env.BASE_URL}/logo_simple.svg`} alt="ScamHelp" class="w-7 lg:w-auto lg:h-9" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-0.5">
        {navLinks.map((link) => (
          <div class={link.children ? "nav-dropdown" : "relative"}>
            <a
              href={link.href}
              class="px-3.5 py-2 text-white hover:text-white/80 transition-colors duration-200 flex items-center gap-1"
              style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:500"
            >
              {link.label}
              {link.children && (
                <svg class="w-3 h-3 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {link.children && (
              <div class="nav-dropdown-menu">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-3.5 py-2.5 text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-150"
                    style="font-family:'Montserrat',sans-serif;font-size:13px"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- CTA Desktop -->
      <div class="hidden lg:block">
        <a
          href="#consultation"
          class="btn-scale inline-flex items-center px-5 py-2 bg-[#9ACF84] text-[#0a0a0f] rounded-lg hover:bg-[#8BC275] transition-colors duration-200"
          style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600"
        >
          Free Consultation
        </a>
      </div>

      <!-- Mobile Toggle -->
      <button id="mobile-toggle" class="lg:hidden text-white p-2 -mr-2" aria-label="Toggle menu">
        <!-- Menu icon -->
        <svg id="icon-menu" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon -->
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden border-t border-white/5">
    <div class="px-6 py-5 space-y-0.5">
      {navLinks.map((link) => (
        <div>
          <a
            href={link.href}
            class="mobile-link block py-3 text-white transition-colors"
            style="font-family:'Montserrat',sans-serif;font-size:15px;font-weight:500"
          >
            {link.label}
          </a>
          {link.children && (
            <div class="pl-4 space-y-0.5 mb-1">
              {link.children.map((child) => (
                <a
                  href={child.href}
                  class="mobile-link block py-2 text-white/35 hover:text-[#9ACF84] transition-colors"
                  style="font-family:'Montserrat',sans-serif;font-size:13px"
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="pt-4">
        <a
          href="#consultation"
          class="mobile-link block text-center px-5 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-lg"
          style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600;box-shadow:0 4px 20px rgba(154,207,132,0.45), 0 2px 8px rgba(0,0,0,0.3)"
        >
          Free Consultation
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Navbar entry animation -->
<style>
  #navbar {
    animation: nav-enter 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes nav-enter {
    from { transform: translateY(-100%); opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }
</style>

<script>
  // Scroll detection
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  }, { passive: true });

  // Mobile toggle
  const toggle    = document.getElementById('mobile-toggle');
  const menu      = document.getElementById('mobile-menu');
  const iconMenu  = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('open');
    if (isOpen) {
      menu?.classList.remove('open');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    } else {
      menu?.classList.add('open');
      iconMenu?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
    }
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.remove('open');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
