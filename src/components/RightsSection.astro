---
const steps = [
  {
    title: "Documentation",
    description: "Gather all relevant documents, such as transaction records and communications.",
    // ClipboardList icon path
    iconPath: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h.01M9 16h.01M12 12h3M9 12h.01M12 16h3",
  },
  {
    title: "Case Analysis",
    description: "Our anti fraud specialists analyze your case to identify the best legal approach.",
    // BarChart3 icon path
    iconPath: "M18 20V10M12 20V4M6 20v-6",
  },
  {
    title: "Action Plan",
    description: "We guide you through the process of disputing charges and contacting financial institutions or regulatory bodies.",
    // Compass icon path
    iconPath: "M12 2a10 10 0 100 20A10 10 0 0012 2zm0 0v2m0 16v2M2 12h2m16 0h2m-4.22-5.78l-1.42 1.42M7.64 16.36l-1.42 1.42m0-11.56l1.42 1.42M16.36 16.36l1.42 1.42M15 12a3 3 0 11-6 0 3 3 0 016 0z",
  },
];
---

<section id="rights" class="py-16 md:py-20 bg-white relative overflow-hidden">
  <!-- Green accent blob -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#9ACF84]/4 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">

      <!-- Text column -->
      <div class="reveal from-left">
        <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">
          Know Your Rights
        </span>
        <h2 class="text-[#0a0a0f] mb-6" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
          Understanding and Asserting Your{" "}
          <span class="text-[#6BA055]">Legal Protection</span>
        </h2>
        <p class="text-[#555] mb-4" style="font-size:15px;line-height:1.8">
          When confronted with unauthorized charges or deceitful schemes, the pathway to
          recovery is governed by clear legal provisions designed to protect consumers.
          At Scam Help, we don't just offer scam assistance—we empower you with knowledge and tools.
        </p>
        <h3 class="text-[#0a0a0f] mb-5 mt-8" style="font-family:'Montserrat',sans-serif;font-size:17px;font-weight:600">
          Steps to Take After Identifying Fraud
        </h3>

        <div class="space-y-5">
          {steps.map((step, i) => (
            <div class={`reveal from-left delay-${i + 2} flex gap-4 group`}>
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#9ACF84] flex items-center justify-center group-hover:bg-[#7BB968] transition-colors duration-200">
                <svg class="w-5 h-5 text-[#2d5a1e]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={step.iconPath} />
                </svg>
              </div>
              <div>
                <h4 class="text-[#0a0a0f] mb-0.5" style="font-family:'Montserrat',sans-serif;font-size:15px;font-weight:600">
                  {step.title}
                </h4>
                <p class="text-[#777]" style="font-size:14px;line-height:1.6">
                  {step.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Image column — desktop: 3D floating cards, mobile: flat image + card grid -->
      <div class="reveal from-right relative rights-img-col" style="perspective:1200px;">

        <!-- Image -->
        <div class="rounded-xl overflow-hidden rights-img" style="transform:rotateY(-10deg);box-shadow:-24px 16px 60px rgba(0,0,0,0.18), -8px 6px 20px rgba(0,0,0,0.12);">
          <img
            src="https://images.unsplash.com/photo-1758519288480-1489c17b1519?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxsZWdhbCUyMGRvY3VtZW50JTIwcHJvZmVzc2lvbmFsJTIwb2ZmaWNlfGVufDF8fHx8MTc3MjQ4Mzk2M3ww&ixlib=rb-4.1.0&q=80&w=1080"
            alt="Legal protection documents"
            class="w-full h-[520px] object-cover rights-img-el"
            loading="lazy"
          />
        </div>

        <!-- Floating cards -->
        <!-- bottom left -->
          <div class="absolute -bottom-6 left-6 z-10 floating-card-wrapper" style="perspective:800px;transform-style:preserve-3d;">
            <div class="floating-card-rotate" style="transform:rotateY(-10deg);transition:transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);">
              <div style="animation:float-card-1 8s ease-in-out infinite;">
                <div class="bg-white border border-[#e8e8e8] rounded-xl p-5 max-w-[260px] reveal delay-4" style="box-shadow:0 8px 30px rgba(0,0,0,0.12);">
                  <div class="flex items-center gap-2.5 mb-2">
                    <div class="w-10 h-10 rounded-lg bg-[#9ACF84] flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-[#2d5a1e]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                    <span class="text-[#0a0a0f]" style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600">Your Rights Are Protected</span>
                  </div>
                  <p class="text-[#888]" style="font-size:12px;line-height:1.5">EU & international consumer protection laws empower you to recover unauthorized charges.</p>
                </div>
              </div>
            </div>
          </div>
          <!-- top right -->
          <div class="absolute -top-5 right-4 z-10 floating-card-wrapper" style="perspective:800px;transform-style:preserve-3d;">
            <div class="floating-card-rotate" style="transform:rotateY(-10deg);transition:transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);">
              <div style="animation:float-card-2 9s ease-in-out infinite;">
                <div class="bg-white border border-[#e8e8e8] rounded-xl p-4 max-w-[230px] reveal delay-5" style="box-shadow:0 8px 30px rgba(0,0,0,0.12);">
                  <div class="flex items-center gap-2.5 mb-1.5">
                    <div class="w-10 h-10 rounded-lg bg-[#9ACF84] flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-[#2d5a1e]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                    </div>
                    <span class="text-[#0a0a0f]" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">Expert Legal Team</span>
                  </div>
                  <p class="text-[#888]" style="font-size:11px;line-height:1.5">Dedicated fraud recovery specialists with proven track records.</p>
                </div>
              </div>
            </div>
          </div>
          <!-- middle right -->
          <div class="absolute top-[60%] -translate-y-1/2 -right-4 z-10 floating-card-wrapper" style="perspective:800px;transform-style:preserve-3d;">
            <div class="floating-card-rotate" style="transform:rotateY(-10deg);transition:transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);">
              <div style="animation:float-card-3 10s ease-in-out infinite;">
                <div class="bg-white border border-[#e8e8e8] rounded-xl p-4 max-w-[210px] reveal delay-6" style="box-shadow:0 8px 30px rgba(0,0,0,0.12);">
                  <div class="flex items-center gap-2.5 mb-1.5">
                    <div class="w-10 h-10 rounded-lg bg-[#9ACF84] flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-[#2d5a1e]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
                    </div>
                    <span class="text-[#0a0a0f]" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">Full Compliance</span>
                  </div>
                  <p class="text-[#888]" style="font-size:11px;line-height:1.5">All actions taken within regulatory frameworks & legal standards.</p>
                </div>
              </div>
            </div>
          </div>
      </div>

    </div>
  </div>
</section>

<style>
  .floating-card-wrapper:hover .floating-card-rotate {
    transform: rotateY(0deg) !important;
  }

  @media (max-width: 1079px) {
    .rights-img                { transform: none !important; box-shadow: 0 8px 30px rgba(0,0,0,0.12) !important; }
    .rights-img-col            { perspective: none !important; }
    .rights-img-col .floating-card-rotate { transform: none !important; }
  }
</style>
