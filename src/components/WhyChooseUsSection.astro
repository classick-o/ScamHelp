---
const { BASE_URL } = import.meta.env;
const reasons = [
  {
    title: "Top Industry Leaders",
    description: "Our global team of AML and law experts excel in resolving complex cases worldwide and provide help for fraud victims.",
    // Users icon
    iconPath: "M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100 8 4 4 0 000-8zm7 0a4 4 0 100 8 4 4 0 000-8m6 14v-2a4 4 0 00-3-3.87",
  },
  {
    title: "Swift Solutions",
    description: "Leverage our online Scam Help's extensive knowledge for prompt case processing and resolution.",
    // Zap icon
    iconPath: "M13 2L3 14h9l-1 8 10-12h-9l1-8z",
  },
  {
    title: "Customized dispute resolution",
    description: "Experience personalized attention with our tailored approach, ensuring in-depth analysis and effective solutions.",
    // Settings icon
    iconPath: "M12 15a3 3 0 100-6 3 3 0 000 6zM19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z",
  },
  {
    title: "Diverse Scam Expertise",
    description: "We specialize in addressing various scams, from intricate fraud schemes to cybercrime.",
    // ShieldCheck icon
    iconPath: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z",
  },
];
---

<section class="py-16 md:py-20 relative overflow-hidden">
  <!-- Video background -->
  <video
    class="absolute inset-0 w-full h-full object-cover"
    src={`${BASE_URL}/why_us_section_video.mp4`}
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true"
  ></video>
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-[#0a0a0f]/80"></div>


  <!-- Marquee text background removed — moved to ScamTypesSection -->
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Heading -->
    <div class="reveal text-center mb-16">
      <span class="text-[#9ACF84] uppercase tracking-[0.2em] mb-5 block" style="font-family:'Montserrat',sans-serif;font-size:11px;font-weight:600">
        Why Choose Us
      </span>
      <h2 class="text-white" style="font-family:'Montserrat',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:600;line-height:1.15">
        Why Choose Us For{" "}
        <span class="text-[#9ACF84]">Scam Victim Help?</span>
      </h2>
    </div>

    <!-- Cards grid -->
    <div class="grid md:grid-cols-2 gap-4">
      {reasons.map((reason, i) => (
        <div class={`reveal delay-${i + 1} group p-4 md:p-7 rounded-xl border border-white/5 bg-white/[0.04] backdrop-blur-md hover:bg-white/[0.07] hover:border-[#9ACF84]/15 transition-all duration-300 relative overflow-hidden`}>
          <div class="absolute inset-0 bg-gradient-to-br from-[#9ACF84]/0 to-[#9ACF84]/0 group-hover:from-[#9ACF84]/3 group-hover:to-transparent transition-all duration-300 pointer-events-none"></div>
          <div class="relative z-10">
            <div class="flex items-center gap-4 mb-3">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[#9ACF84]/8 flex items-center justify-center group-hover:bg-[#9ACF84]/12 transition-colors duration-200">
                <svg class="w-5 h-5 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={reason.iconPath} />
                </svg>
              </div>
              <h3 class="text-white" style="font-family:'Montserrat',sans-serif;font-size:16px;font-weight:600">
                {reason.title}
              </h3>
            </div>
            <p class="text-white/40" style="font-size:14px;line-height:1.65">
              {reason.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Process text + CTA -->
    <div id="why-cta-box" class="reveal delay-5 mt-12 p-8 rounded-xl bg-white/[0.04] backdrop-blur-md border border-white/5 cursor-pointer lg:cursor-default">
      <p id="why-cta-text" class="text-white/35 mb-6" style="font-size:14px;line-height:1.85">
        Scam Help leverages regulations and consumer rights for professional recovery services.
        Upon validating your request and confirming fraud, our online fraud help guides you through
        the refund process, deciding on the best recovery approach together. Benefit from a free
        consultation to initiate your case, with our team representing you before the fraudulent
        company, banks, regulators, and relevant entities. Our global partners, comprising former
        law enforcement officers and banking specialists, bring unique anti-fraud solutions with
        the highest ethical standards, ensuring optimal asset recovery for our clients.
      </p>
      <a
        href="#consultation"
        class="btn-scale inline-flex items-center gap-2 px-7 py-3 bg-[#9ACF84] text-[#0a0a0f] rounded-xl hover:bg-[#8BC275] transition-colors duration-200"
        style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600"
      >
        Contact Us
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  const box  = document.getElementById('why-cta-box');
  const para = document.getElementById('why-cta-text');
  if (!box || !para) throw new Error();

  const fullText = para.textContent?.trim() ?? '';
  const words    = fullText.split(/\s+/);
  const LIMIT    = 30;
  let expanded   = false;

  function isMobile() { return window.innerWidth < 1024; }

  function truncate() {
    para.innerHTML =
      words.slice(0, LIMIT).join(' ') +
      '<span style="color:rgba(255,255,255,0.35)"> ...</span>';
  }

  para.style.overflow   = 'hidden';
  para.style.transition = 'max-height 0.45s ease';

  function init() {
    if (!isMobile()) {
      para.textContent  = fullText;
      para.style.maxHeight = 'none';
      return;
    }
    truncate();
    requestAnimationFrame(() => {
      para.style.maxHeight = para.scrollHeight + 'px';
    });
  }

  init();

  box.addEventListener('click', (e) => {
    if (!isMobile() || expanded) return;
    if ((e.target as HTMLElement).closest('a')) return;
    expanded = true;
    para.textContent = fullText;
    para.style.maxHeight = para.scrollHeight + 'px';
  });

  window.addEventListener('resize', () => {
    if (!isMobile()) {
      para.textContent     = fullText;
      para.style.maxHeight = 'none';
      expanded = false;
    } else if (!expanded) {
      truncate();
      para.style.maxHeight = para.scrollHeight + 'px';
    }
  });
</script>
