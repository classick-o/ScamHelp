---
const footerLinks: Record<string, string[]> = {
  Company:   ["About us", "Our Partners", "News"],
  Services:  ["Fund Recovery", "Crypto Tracing", "Crypto Investigation", "Dispute Resolution"],
  Resources: ["Know your rights", "Common Scams", "FAQ"],
  Legal:     ["Privacy Policy", "Terms of Service", "Cookie Policy"],
};
---

<footer class="relative pt-16 pb-8 bg-[#0a0a0f] overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#9ACF84]/10 to-transparent"></div>
  <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-[#9ACF84]/2 rounded-full blur-[200px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">

    <!-- CTA Bar -->
    <div class="reveal flex flex-col md:flex-row items-center justify-between gap-6 p-8 rounded-xl bg-gradient-to-r from-[#9ACF84] to-[#7BB968] mb-20">
      <div>
        <h3 style="font-family:'Montserrat',sans-serif;font-size:22px;font-weight:700;color:#0a0a0f">
          Ready to get your money back?
        </h3>
        <p style="font-size:14px;color:rgba(10,10,15,0.6)">
          Free consultation — no obligation — confidential assessment.
        </p>
      </div>
      <a
        href="#consultation"
        class="btn-scale inline-flex items-center gap-2 px-7 py-3 bg-[#0a0a0f] text-white rounded-xl hover:bg-[#1a1a28] transition-colors duration-200"
        style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600"
      >
        Get Started
        <!-- ArrowUpRight -->
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M7 7h10v10" />
        </svg>
      </a>
    </div>

    <!-- Links Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-6 gap-10 mb-16">

      <!-- Company info -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-8 h-8 rounded-lg bg-[#9ACF84] flex items-center justify-center">
            <span style="font-family:'Montserrat',sans-serif;font-size:14px;font-weight:800;color:#0a0a0f">S</span>
          </div>
          <span style="font-family:'Montserrat',sans-serif;font-size:18px;font-weight:700;color:white">
            Scam<span class="text-[#9ACF84]">Help</span>
          </span>
        </div>
        <p class="text-white/25 mb-6" style="font-size:13px;line-height:1.7">
          Registered in The Netherlands under Transparent Business Solutions B.V.,
          Company Number 78091624. Helping scam victims worldwide recover their funds.
        </p>
        <div class="space-y-2.5">
          <div class="flex items-center gap-3">
            <!-- Mail -->
            <svg class="w-3.5 h-3.5 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="text-white/35" style="font-size:13px">support@scamhelp.net</span>
          </div>
          <div class="flex items-center gap-3">
            <!-- Phone -->
            <svg class="w-3.5 h-3.5 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="text-white/35" style="font-size:13px">+31 70 701 3260</span>
          </div>
          <div class="flex items-center gap-3">
            <!-- MapPin -->
            <svg class="w-3.5 h-3.5 text-[#9ACF84]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/35" style="font-size:13px">Kalvermarkt 53, 2511 CB Den Haag</span>
          </div>
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(footerLinks).map(([title, links]) => (
        <div>
          <h4 class="text-white/60 mb-4" style="font-family:'Montserrat',sans-serif;font-size:13px;font-weight:600">
            {title}
          </h4>
          <ul class="space-y-2">
            {links.map((link) => (
              <li>
                <a href="#" class="text-white/25 hover:text-[#9ACF84] transition-colors duration-200" style="font-size:13px">
                  {link}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-white/5">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-white/15" style="font-size:12px">
          &copy; 2026 Scam Help. All rights reserved. Mon-Fri: 9:00 AM - 7:00 PM
        </p>
        <div class="flex items-center gap-5">
          {["English", "Dutch", "Italian", "Spanish"].map((lang) => (
            <span class="text-white/20 hover:text-[#9ACF84] cursor-pointer transition-colors" style="font-size:12px">
              {lang}
            </span>
          ))}
        </div>
      </div>
    </div>

  </div>
</footer>
