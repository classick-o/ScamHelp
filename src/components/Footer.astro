---
const footerLinks: Record<string, string[]> = {
  Company:   ["About us", "Our Partners", "News"],
  Services:  ["Fund Recovery", "Crypto Tracing", "Crypto Investigation", "Dispute Resolution"],
  Resources: ["Know your rights", "Common Scams", "FAQ"],
  Legal:     ["Privacy Policy", "Terms of Service", "Cookie Policy"],
};
---

<footer class="relative pt-16 pb-8 bg-[#0a0a0f] overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#9ACF84]/10 to-transparent"></div>
  <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-[#9ACF84]/2 rounded-full blur-[200px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">


    <!-- Links Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-6 gap-10 mb-16">

      <!-- Company info -->
      <div class="lg:col-span-2">
        <div class="mb-5">
